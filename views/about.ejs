<%- include('partials/header', { pageTitle: 'About' }) %>
<section class="section">
  <div class="container narrow">
    <header class="section-header">
      <h2 class="section-title">About This Tribute</h2>
      <div class="section-rule"></div>
    </header>
    <p style="margin-bottom:1rem">The Capoccia–Miotto Family Reunion Tribute is a permanent digital family archive. It began as a place to honor reunions held since <strong>1977</strong> and to invite every generation to keep adding photographs, names, and stories.</p>
    <p style="margin-bottom:1rem">We do not invent family history. Placeholders remain until the family provides accurate information. Both Capoccia and Miotto lineages are welcomed with equal respect.</p>
    <p style="margin-bottom:1.5rem">This site is designed for grandparents and grandchildren alike—large text, clear buttons, and a simple photo contribution path.</p>
    <a class="btn btn-primary" href="/contribute">Contribute Photos</a>
  </div>
</section>
<%- include('partials/footer') %>
