<%- include('../partials/header', { pageTitle: 'Admin Members' }) %>
<section class="section" style="padding-top:1rem">
  <div class="container admin-shell">
    <aside class="admin-nav">
      <a href="/admin">Dashboard</a>
      <a href="/admin/photos">Photos</a>
      <a href="/admin/stories">Stories</a>
      <a href="/admin/recordings">Voice Recordings</a>
      <a href="/admin/board">Board</a>
      <a class="active" href="/admin/members">Family Members</a>
      <a href="/admin/reunions">Reunions</a>
      <a href="/admin/pins">Family PINs</a>
    </aside>
    <div class="admin-main">
      <h2 class="section-title" style="font-size:1.8rem;margin-bottom:1rem">Family members</h2>

      <h3 style="font-family:var(--font-display);font-size:1.35rem;margin:0 0 0.75rem">Name submissions</h3>
      <% if (!submissions || !submissions.length) { %>
        <p style="margin-bottom:1.5rem;color:var(--ink-muted)">No name submissions yet.</p>
      <% } else { %>
        <div class="table-wrap" style="margin-bottom:2rem">
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Relation / branch</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% submissions.forEach(function(s) { %>
                <tr>
                  <td>
                    <strong><%= s.preferred_name || s.full_name %></strong>
                    <% if (s.preferred_name && s.preferred_name !== s.full_name) { %><br /><span style="color:var(--ink-muted)"><%= s.full_name %></span><% } %>
                    <br /><span style="font-size:0.85rem;color:var(--ink-muted)">Submitted by <%= s.contributor_name || 'Family' %><% if (s.contributor_email) { %> · <%= s.contributor_email %><% } %></span>
                    <% if (s.short_bio) { %><br /><span style="font-size:0.88rem"><%= s.short_bio.slice(0, 160) %></span><% } %>
                    <% if (s.spouse_full_name) { %>
                      <br /><span style="font-size:0.9rem;color:var(--burgundy)"><strong>Spouse:</strong> <%= s.spouse_preferred_name || s.spouse_full_name %><% if (s.spouse_preferred_name && s.spouse_preferred_name !== s.spouse_full_name) { %> <span style="color:var(--ink-muted)">(<%= s.spouse_full_name %>)</span><% } %><% if (s.spouse_maiden_name) { %> · maiden <%= s.spouse_maiden_name %><% } %></span>
                    <% } %>
                  </td>
                  <td>
                    <%= s.relation_to_family || '—' %><br />
                    <span style="color:var(--ink-muted)">
                      <%= s.family_branch %>
                      <% if (s.relation_type) { %> · <%= s.relation_type.replace(/_/g, ' ') %><% } %>
                      <% if (s.tree_lineage) { %> · line: <%= s.tree_lineage %><% } %>
                      <% if (s.parent_member_id) { %> · under #<%= s.parent_member_id %><% } %>
                      <% if (s.role_in_family) { %> · <%= s.role_in_family %><% } %>
                      <% if (s.spouse_full_name) { %> · + spouse<% } %>
                    </span>
                  </td>
                  <td><%= s.status %></td>
                  <td class="inline-actions">
                    <% if (s.status !== 'approved') { %>
                      <form method="post" action="/admin/member-submissions/<%= s.id %>/approve">
                        <button class="btn btn-secondary" type="submit">Approve &amp; publish</button>
                      </form>
                    <% } else if (s.family_member_id) { %>
                      <a href="/family-members/<%= s.family_member_id %>">View</a>
                    <% } %>
                    <% if (s.status !== 'rejected') { %>
                      <form method="post" action="/admin/member-submissions/<%= s.id %>/reject">
                        <button class="btn btn-outline" type="submit">Reject</button>
                      </form>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <form class="form-card" method="post" action="/admin/members" style="margin-bottom:2rem">
        <h3 style="font-family:var(--font-display);margin-bottom:0.75rem">Add family member</h3>
        <div class="form-row two">
          <div><label>Full name *</label><input name="full_name" required /></div>
          <div><label>Preferred display name</label><input name="preferred_name" /></div>
        </div>
        <div class="form-row two">
          <div>
            <label>Branch</label>
            <select name="family_branch">
              <option value="Capoccia">Capoccia</option>
              <option value="Miotto">Miotto</option>
              <option value="both">Both</option>
            </select>
          </div>
          <div><label>Sort order</label><input name="sort_order" type="number" value="50" /></div>
        </div>
        <div class="form-row"><label>Role in family</label><input name="role_in_family" /></div>
        <div class="form-row">
          <label>Place under (parent on tree)</label>
          <select name="parent_member_id">
            <option value="">— none / root leader —</option>
            <% members.forEach(function(m) { %>
              <option value="<%= m.id %>"><%= m.preferred_name || m.full_name %></option>
            <% }) %>
          </select>
        </div>
        <fieldset class="form-fieldset spouse-fields">
          <legend>Spouse (optional)</legend>
          <div class="form-row two">
            <div><label>Spouse full name</label><input name="spouse_full_name" maxlength="160" placeholder="Leave blank if none" /></div>
            <div><label>Spouse preferred name</label><input name="spouse_preferred_name" maxlength="160" /></div>
          </div>
          <div class="form-row"><label>Spouse maiden name</label><input name="spouse_maiden_name" maxlength="120" /></div>
        </fieldset>
        <div class="form-row"><label>Biography</label><textarea name="biography"></textarea></div>
        <label class="checkbox"><input type="checkbox" name="is_patriarch" value="1" /> Patriarch</label>
        <label class="checkbox"><input type="checkbox" name="is_matriarch" value="1" /> Matriarch</label>
        <label class="checkbox"><input type="checkbox" name="is_placeholder" value="0" /> Mark as confirmed (not placeholder)</label>
        <button class="btn btn-primary" type="submit" style="margin-top:0.75rem">Add member</button>
      </form>

      <% members.forEach(function(m) { %>
        <form class="form-card" method="post" action="/admin/members/<%= m.id %>" style="margin-bottom:1rem">
          <div class="form-row two">
            <div><label>Full name</label><input name="full_name" value="<%= m.full_name %>" required /></div>
            <div><label>Preferred / display name</label><input name="preferred_name" value="<%= m.preferred_name || '' %>" /></div>
          </div>
          <% if (m.is_matriarch && m.family_branch === 'Capoccia') { %>
            <label class="checkbox"><input type="checkbox" name="update_matriarch_setting" value="1" checked /> Update site-wide Capoccia matriarch display name (Christine / Christina)</label>
          <% } %>
          <div class="form-row two">
            <div>
              <label>Branch</label>
              <select name="family_branch">
                <option value="Capoccia" <%= m.family_branch==='Capoccia'?'selected':'' %>>Capoccia</option>
                <option value="Miotto" <%= m.family_branch==='Miotto'?'selected':'' %>>Miotto</option>
                <option value="both" <%= m.family_branch==='both'?'selected':'' %>>Both</option>
              </select>
            </div>
            <div><label>Sort order</label><input name="sort_order" type="number" value="<%= m.sort_order %>" /></div>
          </div>
          <div class="form-row"><label>Role</label><input name="role_in_family" value="<%= m.role_in_family || '' %>" /></div>
          <div class="form-row"><label>Biography</label><textarea name="biography"><%= m.biography || '' %></textarea></div>
          <div class="form-row"><label>Favorite memories</label><textarea name="favorite_memories"><%= m.favorite_memories || '' %></textarea></div>
          <div class="form-row"><label>Quotes</label><textarea name="quotes"><%= m.quotes || '' %></textarea></div>
          <label class="checkbox"><input type="checkbox" name="is_patriarch" value="1" <%= m.is_patriarch?'checked':'' %> /> Patriarch</label>
          <label class="checkbox"><input type="checkbox" name="is_matriarch" value="1" <%= m.is_matriarch?'checked':'' %> /> Matriarch</label>
          <label class="checkbox"><input type="checkbox" name="is_placeholder" value="1" <%= m.is_placeholder?'checked':'' %> /> Placeholder (incomplete info)</label>
          <button class="btn btn-outline" type="submit" style="margin-top:0.75rem">Save <%= m.full_name %></button>
        </form>
      <% }) %>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
