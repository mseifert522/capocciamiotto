<%- include('../partials/header', { pageTitle: 'Manage Photos' }) %>
<section class="section" style="padding-top:1rem">
  <div class="container admin-shell">
    <aside class="admin-nav">
      <a href="/admin">Dashboard</a>
      <a href="/admin/home-photos">Home Photos</a>
      <a href="/admin/special-memories">Special Memories</a>
      <a class="active" href="/admin/photos">Photos</a>
      <a href="/admin/stories">Stories</a>
      <a href="/admin/recordings">Voice Recordings</a>
      <a href="/admin/board">Board</a>
      <a href="/admin/members">Family Members</a>
      <a href="/admin/reunions">Reunions</a>
      <a href="/admin/pins">Family PINs</a>
    </aside>
    <div class="admin-main">
      <h2 class="section-title" style="font-size:1.8rem;margin-bottom:0.5rem">Photograph archive</h2>
      <p class="hint" style="margin-bottom:1rem">
        Family PIN uploads are approved automatically and appear in the public Photo Archive right away.
        Use this screen to edit details, nominate for the home page, or permanently delete mistakes / test uploads.
      </p>
      <p style="margin-bottom:1rem">
        <a href="/admin/photos?status=all">All (<%= typeof counts !== 'undefined' ? counts.all : '—' %>)</a> ·
        <a href="/admin/photos?status=approved">Approved (<%= typeof counts !== 'undefined' ? counts.approved : '—' %>)</a> ·
        <a href="/admin/photos?status=pending">Pending (<%= typeof counts !== 'undefined' ? counts.pending : '—' %>)</a> ·
        <a href="/admin/photos?status=rejected">Rejected (<%= typeof counts !== 'undefined' ? counts.rejected : '—' %>)</a>
        · <strong>viewing: <%= status %></strong>
      </p>
      <form method="post" action="/admin/photos/purge-tests" style="margin-bottom:1.25rem" onsubmit="return confirm('Remove automated test photographs and test board posts? Real family photos are kept.');">
        <button class="btn btn-outline" type="submit">Delete automated test photos</button>
      </form>
      <% if (!photos || !photos.length) { %>
        <div class="empty"><h3>No photographs in this filter.</h3></div>
      <% } else { %>
      <div class="table-wrap"><table>
        <thead><tr><th>Photo</th><th>Info</th><th>Edit / actions</th></tr></thead>
        <tbody>
        <% photos.forEach(function(p) { %>
          <tr>
            <td><% if (p.web_path || p.thumb_path) { %><img class="thumb-sm" src="<%= p.thumb_path || p.web_path %>" alt="" /><% } %></td>
            <td>
              <strong><%= p.title || p.original_filename || ('Photo #' + p.id) %></strong>
              <span style="display:inline-block;margin-left:0.35rem;font-size:0.8rem;color:var(--ink-muted)">[<%= p.status %>]</span><br />
              By <%= p.contributor_name || '—' %> · <%= p.submitted_at %><br />
              Year: <%= p.reunion_year || 'TBD' %>
              <% if (p.show_on_home || p.home_status) { %> · home: <%= p.home_status || (p.show_on_home ? 'live' : '—') %><% } %>
              <% if (p.special_memory) { %> · <strong>Special Memory</strong><% } %><br />
              People: <%= (people[p.id] || []).map(x => x.person_name).join(', ') || '—' %>
            </td>
            <td>
              <form method="post" action="/admin/photos/<%= p.id %>/update">
                <input type="hidden" name="return_status" value="<%= status %>" />
                <div class="form-row"><label>Title</label><input name="title" value="<%= p.title || '' %>" /></div>
                <div class="form-row"><label>Year</label><input name="reunion_year" type="number" value="<%= p.reunion_year || '' %>" /></div>
                <div class="form-row"><label>Branch</label>
                  <select name="family_branch">
                    <option value="both" <%= p.family_branch==='both'?'selected':'' %>>Both</option>
                    <option value="Capoccia" <%= p.family_branch==='Capoccia'?'selected':'' %>>Capoccia</option>
                    <option value="Miotto" <%= p.family_branch==='Miotto'?'selected':'' %>>Miotto</option>
                  </select>
                </div>
                <div class="form-row"><label>Location</label><input name="location" value="<%= p.location || '' %>" /></div>
                <div class="form-row"><label>Description</label><textarea name="description"><%= p.description || '' %></textarea></div>
                <div class="form-row"><label>Admin notes</label><textarea name="admin_notes"><%= p.admin_notes || '' %></textarea></div>
                <label class="checkbox"><input type="checkbox" name="featured" value="1" <%= p.featured ? 'checked' : '' %> /> Featured (year cover preference)</label>
                <label class="checkbox"><input type="checkbox" name="special_memory" value="1" <%= p.special_memory ? 'checked' : '' %> /> Special Memories (main showcase on Photo Archive)</label>
                <div class="form-row" style="margin-top:0.35rem">
                  <label>Special Memories sort order</label>
                  <input type="number" name="special_sort" value="<%= p.special_sort || 0 %>" style="max-width:8rem" />
                </div>
                <label class="checkbox"><input type="checkbox" name="show_on_home" value="1" <%= (p.show_on_home || p.home_status === 'pending' || p.home_status === 'approved') ? 'checked' : '' %> /> Nominate for home page (still needs Approve under Home Photos)</label>
                <div class="form-row" style="margin-top:0.35rem">
                  <label>Home page sort order</label>
                  <input type="number" name="home_sort" value="<%= p.home_sort || 0 %>" style="max-width:8rem" />
                </div>
                <div class="inline-actions" style="margin-top:0.5rem">
                  <button class="btn btn-outline" type="submit">Save</button>
                </div>
              </form>
              <div class="inline-actions" style="margin-top:0.5rem">
                <% if (p.status !== 'approved') { %>
                  <form method="post" action="/admin/photos/<%= p.id %>/approve"><button class="btn btn-secondary" type="submit">Approve / show in archive</button></form>
                <% } %>
                <% if (p.status !== 'rejected') { %>
                  <form method="post" action="/admin/photos/<%= p.id %>/reject"><button class="btn btn-outline" type="submit">Reject / hide</button></form>
                <% } %>
                <form method="post" action="/admin/photos/<%= p.id %>/delete" onsubmit="return confirm('Permanently delete this photograph from the archive?');">
                  <input type="hidden" name="return_status" value="<%= status %>" />
                  <button class="btn btn-outline" type="submit" style="color:#8b1e1e;border-color:#8b1e1e">Delete forever</button>
                </form>
              </div>
              <% if (p.original_path || p.web_path) { %><p style="margin-top:0.5rem"><a href="<%= p.original_path || p.web_path %>" target="_blank" rel="noopener">Open file</a></p><% } %>
            </td>
          </tr>
        <% }) %>
        </tbody>
      </table></div>
      <% } %>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
