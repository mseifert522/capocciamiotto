<%- include('../partials/header', { pageTitle: 'Admin Recordings' }) %>
<section class="section" style="padding-top:1rem">
  <div class="container admin-shell">
    <aside class="admin-nav">
      <a href="/admin">Dashboard</a>
      <a href="/admin/photos">Photos</a>
      <a href="/admin/stories">Stories</a>
      <a class="active" href="/admin/recordings">Voice Recordings</a>
      <a href="/admin/board">Board</a>
      <a href="/admin/members">Family Members</a>
      <a href="/admin/reunions">Reunions</a>
      <a href="/admin/pins">Family PINs</a>
    </aside>
    <div class="admin-main">
      <h2 class="section-title" style="font-size:1.8rem;margin-bottom:1rem">Voice recordings</h2>
      <p style="margin-bottom:1rem;color:var(--ink-muted)">Only administrators can upload and publish family voices. The public can listen only.</p>

      <form class="form-card" method="post" action="/admin/recordings/upload" enctype="multipart/form-data" style="margin-bottom:2rem">
        <h3 style="font-family:var(--font-display);margin-bottom:0.75rem">Upload a family voice recording</h3>
        <div class="form-row">
          <label for="speaker_name">Speaker name *</label>
          <input type="text" id="speaker_name" name="speaker_name" required maxlength="160" placeholder="Example: George Capoccia" />
        </div>
        <div class="form-row two">
          <div>
            <label for="family_member_id">Link to family member</label>
            <select id="family_member_id" name="family_member_id">
              <option value="">Not linked</option>
              <% (members || []).forEach(function(m) { %>
                <option value="<%= m.id %>"><%= m.preferred_name || m.full_name %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label for="recording_type">Type</label>
            <select id="recording_type" name="recording_type">
              <option value="story">Family story</option>
              <option value="memory">Memory</option>
              <option value="blessing">Blessing or prayer</option>
              <option value="tradition">Tradition</option>
              <option value="interview">Interview</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>
        <div class="form-row two">
          <div>
            <label for="title">Title</label>
            <input type="text" id="title" name="title" maxlength="200" />
          </div>
          <div>
            <label for="recorded_year">Year recorded</label>
            <input type="number" id="recorded_year" name="recorded_year" min="1977" max="<%= currentYear %>" />
          </div>
        </div>
        <div class="form-row">
          <label for="description">Description</label>
          <textarea id="description" name="description" rows="2" maxlength="3000"></textarea>
        </div>
        <div class="form-row">
          <label for="recording">Audio file *</label>
          <input type="file" id="recording" name="recording" accept="audio/*,.mp3,.m4a,.wav,.ogg,.webm,.aac" required />
        </div>
        <label class="checkbox" style="margin-bottom:0.75rem">
          <input type="checkbox" name="publish" value="1" checked />
          Publish immediately so the family can listen
        </label>
        <button class="btn btn-primary" type="submit">Upload recording</button>
      </form>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Recording</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!recordings.length) { %>
              <tr><td colspan="3">No recordings yet.</td></tr>
            <% } %>
            <% recordings.forEach(function(r) { %>
              <tr>
                <td>
                  <strong><%= r.title || r.speaker_name %></strong><br />
                  Speaker: <%= r.speaker_name %>
                  <% if (r.member_name) { %> · Linked: <%= r.member_name %><% } %><br />
                  <span style="color:var(--ink-muted);font-size:0.85rem">
                    <%= r.recording_type %> · <%= r.contributor_name || 'Family' %>
                    <% if (r.recorded_year) { %> · <%= r.recorded_year %><% } %>
                    · <%= Math.round((r.file_size || 0) / 1024) %> KB
                  </span>
                  <% if (r.description) { %><br /><span style="font-size:0.88rem"><%= (r.description || '').slice(0, 180) %></span><% } %>
                  <div style="margin-top:0.5rem">
                    <audio controls preload="none" src="<%= r.file_path %>" style="width:min(100%,320px)"></audio>
                  </div>
                </td>
                <td><%= r.status %><% if (r.featured) { %><br /><span class="badge badge-both">Featured</span><% } %></td>
                <td class="inline-actions">
                  <% if (r.status !== 'approved') { %>
                    <form method="post" action="/admin/recordings/<%= r.id %>/approve">
                      <button class="btn btn-secondary" type="submit">Approve</button>
                    </form>
                  <% } %>
                  <% if (r.status === 'approved') { %>
                    <form method="post" action="/admin/recordings/<%= r.id %>/feature">
                      <input type="hidden" name="featured" value="<%= r.featured ? '0' : '1' %>" />
                      <button class="btn btn-outline" type="submit"><%= r.featured ? 'Unfeature' : 'Feature' %></button>
                    </form>
                  <% } %>
                  <% if (r.status !== 'rejected') { %>
                    <form method="post" action="/admin/recordings/<%= r.id %>/reject">
                      <button class="btn btn-outline" type="submit">Reject</button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
