<%- include('partials/header', { pageTitle: 'Community Board' }) %>
<%
  function formatBoardWhen(raw) {
    if (!raw) return '';
    var s = String(raw).trim().replace('T', ' ').replace(/\.\d+Z?$/, '');
    // SQLite: "YYYY-MM-DD HH:MM:SS"
    var m = s.match(/^(\d{4})-(\d{2})-(\d{2})(?:[ ](\d{2}):(\d{2})(?::(\d{2}))?)?/);
    if (!m) return s.slice(0, 16);
    var y = m[1], mo = m[2], d = m[3];
    var hh = m[4] || '00', mm = m[5] || '00';
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    var mon = months[parseInt(mo, 10) - 1] || mo;
    var h = parseInt(hh, 10);
    var ampm = h >= 12 ? 'PM' : 'AM';
    var h12 = h % 12;
    if (h12 === 0) h12 = 12;
    return mon + ' ' + parseInt(d, 10) + ', ' + y + ' · ' + h12 + ':' + mm + ' ' + ampm;
  }
  function categoryLabel(cat) {
    var map = {
      announcement: 'Announcement',
      photo_request: 'Photo request',
      identify: 'Identify',
      planning: 'Planning',
      news: 'News',
      recipe: 'Recipe',
      memorial: 'Memorial',
      general: 'General'
    };
    return map[cat] || (cat || 'General');
  }
%>
<section class="section board-section">
  <div class="container board-page">
    <header class="section-header board-page-header">
      <p class="section-eyebrow">Family only · PIN protected</p>
      <h2 class="section-title">Community Board</h2>
      <div class="section-rule"></div>
      <p class="section-lead board-page-lead">
        Share messages with the family. Posts go live right away.
        You can only edit or delete messages you posted from this connection.
      </p>
      <% if (typeof pinHolder !== 'undefined' && pinHolder) { %>
        <p class="board-pin-status">
          Signed in as <strong><%= pinHolder.assignedName %></strong>
        </p>
      <% } %>
    </header>

    <div class="board-layout">
      <aside class="board-compose" aria-label="Post a family message">
        <form
          class="form-card board-compose-form"
          method="post"
          action="/community-board"
          enctype="multipart/form-data"
        >
          <h3 class="board-compose-title">New message</h3>
          <p class="hint board-compose-hint">
            Write a short title and your message. Photos and videos are optional.
          </p>

          <div class="form-row">
            <label for="title">Title *</label>
            <input type="text" id="title" name="title" required maxlength="200" placeholder="Short subject" />
          </div>
          <div class="form-row">
            <label for="category">Category</label>
            <select id="category" name="category">
              <option value="announcement">Announcement</option>
              <option value="photo_request">Request for old photographs</option>
              <option value="identify">Help identify someone</option>
              <option value="planning">Reunion planning</option>
              <option value="news">Family news</option>
              <option value="recipe">Recipe or tradition</option>
              <option value="memorial">Memorial</option>
              <option value="general" selected>General</option>
            </select>
          </div>
          <div class="form-row">
            <label for="body">Message</label>
            <textarea id="body" name="body" maxlength="5000" rows="4" placeholder="Write your message…"></textarea>
          </div>

          <div class="form-row">
            <label>Photos <span class="bulk-label-note">(optional)</span></label>
            <div
              class="dropzone bulk-dropzone bulk-dropzone--board"
              data-bulk-upload
              data-bulk-max="30"
              data-bulk-accept="image"
            >
              <div class="bulk-dropzone-main" data-bulk-trigger>
                <strong>Add photos</strong>
                <span class="hint">Drag &amp; drop or tap to choose</span>
                <span class="bulk-dropzone-limits">Up to 30 · 100MB each</span>
              </div>
              <input
                id="board-photos"
                type="file"
                name="photos"
                accept="image/*,.heic,.heif"
                multiple
                data-bulk-input
                style="position:absolute;left:-9999px;opacity:0;width:1px;height:1px"
              />
              <div class="bulk-toolbar">
                <button type="button" class="btn btn-secondary" data-bulk-add>Add photos</button>
                <button type="button" class="btn btn-outline" data-bulk-clear hidden>Clear</button>
              </div>
              <p class="bulk-count" data-bulk-count>No photos selected.</p>
              <div class="bulk-previews" data-bulk-previews aria-live="polite"></div>
            </div>
          </div>
          <div class="form-row">
            <label>Videos <span class="bulk-label-note">(optional)</span></label>
            <div
              class="dropzone bulk-dropzone bulk-dropzone--board"
              data-bulk-upload
              data-bulk-max="5"
              data-bulk-accept="video"
            >
              <div class="bulk-dropzone-main" data-bulk-trigger>
                <strong>Add videos</strong>
                <span class="hint">MP4, WebM, MOV · up to 5</span>
              </div>
              <input
                id="board-videos"
                type="file"
                name="videos"
                accept="video/mp4,video/webm,video/quicktime,video/*,.mp4,.webm,.mov,.m4v"
                multiple
                data-bulk-input
                style="position:absolute;left:-9999px;opacity:0;width:1px;height:1px"
              />
              <div class="bulk-toolbar">
                <button type="button" class="btn btn-secondary" data-bulk-add>Add videos</button>
                <button type="button" class="btn btn-outline" data-bulk-clear hidden>Clear</button>
              </div>
              <p class="bulk-count" data-bulk-count>No videos selected.</p>
              <div class="bulk-previews bulk-previews--video" data-bulk-previews aria-live="polite"></div>
            </div>
          </div>

          <div class="form-row">
            <label for="author_name">Your name *</label>
            <%
              var boardPinName = (typeof pinHolder !== 'undefined' && pinHolder && pinHolder.assignedName) ? String(pinHolder.assignedName) : '';
              var boardSharedPin = /capoccia/i.test(boardPinName) && /family/i.test(boardPinName);
              var boardAuthorPrefill = (!boardSharedPin && boardPinName) ? boardPinName : '';
            %>
            <input
              type="text"
              id="author_name"
              name="author_name"
              required
              maxlength="120"
              value="<%= boardAuthorPrefill %>"
              placeholder="Your full name"
            />
          </div>
          <div class="form-row">
            <label for="author_email">Email (private)</label>
            <input type="email" id="author_email" name="author_email" maxlength="160" />
          </div>
          <button class="btn btn-primary btn-block" type="submit">Post message</button>
        </form>
      </aside>

      <div class="board-feed-wrap">
        <div class="board-feed-head">
          <div class="board-feed-head-row">
            <h3 class="board-feed-title">Messages</h3>
            <span class="board-feed-count"><%= (posts && posts.length) ? posts.length : 0 %> post<%= (!posts || posts.length === 1) ? '' : 's' %></span>
          </div>
          <p class="hint">Newest first · scroll for more</p>
        </div>
        <div class="board-feed" role="feed" aria-label="Community board messages, newest first">
          <% if (!posts || !posts.length) { %>
            <div class="empty board-feed-empty">
              <h3>No messages yet</h3>
              <p>Be the first to post using the form.</p>
            </div>
          <% } else { %>
            <% posts.forEach(function(post, idx) { %>
              <article
                class="board-post<%= post.is_pinned ? ' pinned' : '' %><%= post.canEdit ? ' is-mine' : '' %>"
                id="board-post-<%= post.id %>"
                aria-posinset="<%= idx + 1 %>"
              >
                <header class="board-post-header">
                  <div class="board-post-identity">
                    <span class="board-post-author"><%= post.author_name || 'Family member' %></span>
                    <time class="board-post-when" datetime="<%= post.created_at || '' %>">
                      <%= formatBoardWhen(post.created_at) %>
                    </time>
                    <% if (post.updated_at && post.created_at && String(post.updated_at).slice(0, 16) !== String(post.created_at).slice(0, 16)) { %>
                      <span class="board-post-edited">edited</span>
                    <% } %>
                  </div>
                  <div class="board-post-tags">
                    <% if (post.is_pinned) { %><span class="board-tag board-tag--pin">Pinned</span><% } %>
                    <span class="board-tag"><%= categoryLabel(post.category) %></span>
                  </div>
                </header>

                <% if (post.title) { %>
                  <h3 class="board-post-title"><%= post.title %></h3>
                <% } %>

                <% if (post.body) { %>
                  <p class="board-post-body"><%= post.body %></p>
                <% } %>

                <% if (post.media && post.media.length) { %>
                  <div class="board-media">
                    <% post.media.forEach(function(m) { %>
                      <% if (m.media_type === 'video') { %>
                        <div class="board-media-item board-media-item--video">
                          <video
                            class="board-video"
                            controls
                            playsinline
                            preload="metadata"
                            src="<%= m.file_path %>"
                          >
                            Your browser does not support video playback.
                          </video>
                        </div>
                      <% } else { %>
                        <a
                          class="board-media-item board-media-item--image"
                          href="<%= m.file_path %>"
                          data-lightbox="<%= m.file_path %>"
                          data-lightbox-caption="<%= post.title || '' %>"
                        >
                          <img
                            src="<%= m.thumb_path || m.file_path %>"
                            alt="<%= m.original_filename || 'Family photo' %>"
                            loading="lazy"
                          />
                        </a>
                      <% } %>
                    <% }) %>
                  </div>
                <% } %>

                <% if (post.canEdit) { %>
                  <div class="board-post-actions">
                    <details class="board-edit-details">
                      <summary class="board-action-link">Edit</summary>
                      <form
                        class="board-edit-form"
                        method="post"
                        action="/community-board/<%= post.id %>/edit"
                      >
                        <div class="form-row">
                          <label for="edit-title-<%= post.id %>">Title *</label>
                          <input type="text" id="edit-title-<%= post.id %>" name="title" required maxlength="200" value="<%= post.title || '' %>" />
                        </div>
                        <div class="form-row">
                          <label for="edit-category-<%= post.id %>">Category</label>
                          <select id="edit-category-<%= post.id %>" name="category">
                            <%
                              var cats = [
                                ['announcement','Announcement'],
                                ['photo_request','Request for old photographs'],
                                ['identify','Help identify someone'],
                                ['planning','Reunion planning'],
                                ['news','Family news'],
                                ['recipe','Recipe or tradition'],
                                ['memorial','Memorial'],
                                ['general','General']
                              ];
                              cats.forEach(function(c) {
                            %>
                              <option value="<%= c[0] %>" <%= post.category === c[0] ? 'selected' : '' %>><%= c[1] %></option>
                            <% }) %>
                          </select>
                        </div>
                        <div class="form-row">
                          <label for="edit-body-<%= post.id %>">Message</label>
                          <textarea id="edit-body-<%= post.id %>" name="body" maxlength="5000" rows="4"><%= post.body || '' %></textarea>
                        </div>
                        <div class="form-row">
                          <label for="edit-name-<%= post.id %>">Your name *</label>
                          <input type="text" id="edit-name-<%= post.id %>" name="author_name" required maxlength="120" value="<%= post.author_name || '' %>" />
                        </div>
                        <div class="board-edit-form-actions">
                          <button class="btn btn-primary btn-sm" type="submit">Save</button>
                        </div>
                      </form>
                    </details>
                    <form
                      method="post"
                      action="/community-board/<%= post.id %>/delete"
                      class="board-delete-form"
                      onsubmit="return confirm('Delete this message? This cannot be undone.');"
                    >
                      <button type="submit" class="board-action-link board-action-link--danger">Delete</button>
                    </form>
                  </div>
                <% } %>
              </article>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
