<%- include('partials/header', { pageTitle: 'Community Board' }) %>
<section class="section board-section">
  <div class="container board-page">
    <header class="section-header board-page-header">
      <p class="section-eyebrow">Family only · PIN protected</p>
      <h2 class="section-title">Community Board</h2>
      <div class="section-rule"></div>
      <% if (typeof pinHolder !== 'undefined' && pinHolder) { %>
        <p class="board-pin-status">
          Signed in as <strong><%= pinHolder.assignedName %></strong>
          · You won’t need the family PIN again on this browser for up to 90 days.
        </p>
      <% } %>
    </header>

    <div class="board-layout">
      <aside class="board-compose" aria-label="Post a family message">
        <form
          class="form-card board-compose-form"
          method="post"
          action="/community-board"
          enctype="multipart/form-data"
        >
          <h3 class="board-compose-title">Post a family message</h3>
          <p class="hint board-compose-hint">
            Share a message, photos, and/or video. Posts appear on the right for the whole family right away.
          </p>

          <div class="form-row">
            <label for="title">Title *</label>
            <input type="text" id="title" name="title" required maxlength="200" placeholder="Short subject" />
          </div>
          <div class="form-row">
            <label for="category">Category</label>
            <select id="category" name="category">
              <option value="announcement">Announcement</option>
              <option value="photo_request">Request for old photographs</option>
              <option value="identify">Help identify someone</option>
              <option value="planning">Reunion planning</option>
              <option value="news">Family news</option>
              <option value="recipe">Recipe or tradition</option>
              <option value="memorial">Memorial</option>
              <option value="general">General</option>
            </select>
          </div>
          <div class="form-row">
            <label for="body">Message</label>
            <textarea id="body" name="body" maxlength="5000" rows="5" placeholder="Write your message to the family… (optional if you attach media)"></textarea>
          </div>

          <div class="form-row">
            <label for="board-photos">Photos</label>
            <input
              id="board-photos"
              type="file"
              name="photos"
              accept="image/*,.heic,.heif"
              multiple
            />
            <p class="hint">JPEG, PNG, WebP, GIF · up to 8 photos · 100MB each max</p>
          </div>
          <div class="form-row">
            <label for="board-videos">Videos</label>
            <input
              id="board-videos"
              type="file"
              name="videos"
              accept="video/mp4,video/webm,video/quicktime,video/*,.mp4,.webm,.mov,.m4v"
              multiple
            />
            <p class="hint">MP4, WebM, MOV · up to 3 videos · 100MB each max</p>
          </div>

          <div class="form-row">
            <label for="author_name">Your name *</label>
            <input
              type="text"
              id="author_name"
              name="author_name"
              required
              maxlength="120"
              value="<%= (typeof pinHolder !== 'undefined' && pinHolder && pinHolder.assignedName) ? pinHolder.assignedName : '' %>"
            />
          </div>
          <div class="form-row">
            <label for="author_email">Email (private)</label>
            <input type="email" id="author_email" name="author_email" maxlength="160" />
          </div>
          <button class="btn btn-primary btn-block" type="submit">Post to Board</button>
        </form>
      </aside>

      <div class="board-feed-wrap">
        <div class="board-feed-head">
          <h3 class="board-feed-title">Family messages</h3>
          <p class="hint">Newest at the top · scroll for older posts · photos &amp; video welcome</p>
        </div>
        <div class="board-feed" role="feed" aria-label="Community board messages, newest first">
          <% if (!posts || !posts.length) { %>
            <div class="empty board-feed-empty">
              <h3>No messages yet</h3>
              <p>Be the first to post a message, photo, or video using the form on the left.</p>
            </div>
          <% } else { %>
            <% posts.forEach(function(post, idx) { %>
              <article class="board-post <%= post.is_pinned ? 'pinned' : '' %>" aria-posinset="<%= idx + 1 %>">
                <h3><%= post.title %></h3>
                <p class="board-meta">
                  <%= post.is_pinned ? 'Pinned · ' : '' %><%= post.category %>
                  · <%= post.author_name || 'Family' %>
                  · <%= (post.created_at || '').slice(0, 10) %>
                  <% if (post.media && post.media.length) { %>
                    · <%= post.media.length %> attachment<%= post.media.length === 1 ? '' : 's' %>
                  <% } %>
                </p>
                <% if (post.body) { %>
                  <p class="board-post-body"><%= post.body %></p>
                <% } %>
                <% if (post.media && post.media.length) { %>
                  <div class="board-media">
                    <% post.media.forEach(function(m) { %>
                      <% if (m.media_type === 'video') { %>
                        <div class="board-media-item board-media-item--video">
                          <video
                            class="board-video"
                            controls
                            playsinline
                            preload="metadata"
                            src="<%= m.file_path %>"
                          >
                            Your browser does not support video playback.
                          </video>
                        </div>
                      <% } else { %>
                        <a
                          class="board-media-item board-media-item--image"
                          href="<%= m.file_path %>"
                          data-lightbox="<%= m.file_path %>"
                          data-lightbox-caption="<%= post.title %>"
                        >
                          <img
                            src="<%= m.thumb_path || m.file_path %>"
                            alt="<%= m.original_filename || 'Family photo' %>"
                            loading="lazy"
                          />
                        </a>
                      <% } %>
                    <% }) %>
                  </div>
                <% } %>
              </article>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
