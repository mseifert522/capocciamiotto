<%- include('partials/header', { pageTitle: 'Community Board' }) %>
<section class="section board-section">
  <div class="container board-page">
    <header class="section-header board-page-header">
      <p class="section-eyebrow">Family only · PIN protected · posts go live automatically</p>
      <h2 class="section-title">Community Board</h2>
      <div class="section-rule"></div>
      <p class="section-lead" style="max-width:42rem;margin-left:auto;margin-right:auto">
        Every family member with the family PIN can post messages, photos, and videos.
        Your post appears for the whole family immediately — no waiting for approval.
      </p>
      <% if (typeof pinHolder !== 'undefined' && pinHolder) { %>
        <p class="board-pin-status">
          Signed in as <strong><%= pinHolder.assignedName %></strong>
          · You won’t need the family PIN again on this browser for up to 90 days.
        </p>
      <% } %>
    </header>

    <div class="board-layout">
      <aside class="board-compose" aria-label="Post a family message">
        <form
          class="form-card board-compose-form"
          method="post"
          action="/community-board"
          enctype="multipart/form-data"
        >
          <h3 class="board-compose-title">Post a family message</h3>
          <p class="hint board-compose-hint">
            Share a message, photos, and/or video. Posts go live on the right for the whole family automatically.
          </p>

          <div class="form-row">
            <label for="title">Title *</label>
            <input type="text" id="title" name="title" required maxlength="200" placeholder="Short subject" />
          </div>
          <div class="form-row">
            <label for="category">Category</label>
            <select id="category" name="category">
              <option value="announcement">Announcement</option>
              <option value="photo_request">Request for old photographs</option>
              <option value="identify">Help identify someone</option>
              <option value="planning">Reunion planning</option>
              <option value="news">Family news</option>
              <option value="recipe">Recipe or tradition</option>
              <option value="memorial">Memorial</option>
              <option value="general">General</option>
            </select>
          </div>
          <div class="form-row">
            <label for="body">Message</label>
            <textarea id="body" name="body" maxlength="5000" rows="5" placeholder="Write your message to the family… (optional if you attach media)"></textarea>
          </div>

          <div class="form-row">
            <label>Photos <span class="bulk-label-note">(bulk / drag &amp; drop)</span></label>
            <div
              class="dropzone bulk-dropzone bulk-dropzone--board"
              data-bulk-upload
              data-bulk-max="30"
              data-bulk-accept="image"
            >
              <div class="bulk-dropzone-main" data-bulk-trigger>
                <strong>Drag &amp; drop photos here</strong>
                <span class="hint">Or tap to choose many photos at once. You can add more before posting.</span>
                <span class="bulk-dropzone-limits">JPEG, PNG, WebP, GIF · up to 30 photos · 100MB each</span>
              </div>
              <input
                id="board-photos"
                type="file"
                name="photos"
                accept="image/*,.heic,.heif"
                multiple
                data-bulk-input
                style="position:absolute;left:-9999px;opacity:0;width:1px;height:1px"
              />
              <div class="bulk-toolbar">
                <button type="button" class="btn btn-secondary" data-bulk-add>Add more photos</button>
                <button type="button" class="btn btn-outline" data-bulk-clear hidden>Clear photos</button>
              </div>
              <p class="bulk-count" data-bulk-count>No photos selected.</p>
              <div class="bulk-previews" data-bulk-previews aria-live="polite"></div>
            </div>
          </div>
          <div class="form-row">
            <label>Videos <span class="bulk-label-note">(optional bulk)</span></label>
            <div
              class="dropzone bulk-dropzone bulk-dropzone--board"
              data-bulk-upload
              data-bulk-max="5"
              data-bulk-accept="video"
            >
              <div class="bulk-dropzone-main" data-bulk-trigger>
                <strong>Drag &amp; drop videos here</strong>
                <span class="hint">Or tap to choose videos. MP4, WebM, MOV · up to 5 · 100MB each</span>
              </div>
              <input
                id="board-videos"
                type="file"
                name="videos"
                accept="video/mp4,video/webm,video/quicktime,video/*,.mp4,.webm,.mov,.m4v"
                multiple
                data-bulk-input
                style="position:absolute;left:-9999px;opacity:0;width:1px;height:1px"
              />
              <div class="bulk-toolbar">
                <button type="button" class="btn btn-secondary" data-bulk-add>Add more videos</button>
                <button type="button" class="btn btn-outline" data-bulk-clear hidden>Clear videos</button>
              </div>
              <p class="bulk-count" data-bulk-count>No videos selected.</p>
              <div class="bulk-previews bulk-previews--video" data-bulk-previews aria-live="polite"></div>
            </div>
          </div>

          <div class="form-row">
            <label for="author_name">Your name *</label>
            <%
              var boardPinName = (typeof pinHolder !== 'undefined' && pinHolder && pinHolder.assignedName) ? String(pinHolder.assignedName) : '';
              var boardSharedPin = /capoccia/i.test(boardPinName) && /family/i.test(boardPinName);
              var boardAuthorPrefill = (!boardSharedPin && boardPinName) ? boardPinName : '';
            %>
            <input
              type="text"
              id="author_name"
              name="author_name"
              required
              maxlength="120"
              value="<%= boardAuthorPrefill %>"
              placeholder="Your full name"
            />
          </div>
          <div class="form-row">
            <label for="author_email">Email (private)</label>
            <input type="email" id="author_email" name="author_email" maxlength="160" />
          </div>
          <button class="btn btn-primary btn-block" type="submit">Post to Board — goes live now</button>
        </form>
      </aside>

      <div class="board-feed-wrap">
        <div class="board-feed-head">
          <h3 class="board-feed-title">Family messages</h3>
          <p class="hint">Newest at the top · scroll for older posts · photos &amp; video welcome</p>
        </div>
        <div class="board-feed" role="feed" aria-label="Community board messages, newest first">
          <% if (!posts || !posts.length) { %>
            <div class="empty board-feed-empty">
              <h3>No messages yet</h3>
              <p>Be the first to post a message, photo, or video using the form on the left.</p>
            </div>
          <% } else { %>
            <% posts.forEach(function(post, idx) { %>
              <article class="board-post <%= post.is_pinned ? 'pinned' : '' %>" aria-posinset="<%= idx + 1 %>">
                <h3><%= post.title %></h3>
                <p class="board-meta">
                  <%= post.is_pinned ? 'Pinned · ' : '' %><%= post.category %>
                  · <%= post.author_name || 'Family' %>
                  · <%= (post.created_at || '').slice(0, 10) %>
                  <% if (post.media && post.media.length) { %>
                    · <%= post.media.length %> attachment<%= post.media.length === 1 ? '' : 's' %>
                  <% } %>
                </p>
                <% if (post.body) { %>
                  <p class="board-post-body"><%= post.body %></p>
                <% } %>
                <% if (post.media && post.media.length) { %>
                  <div class="board-media">
                    <% post.media.forEach(function(m) { %>
                      <% if (m.media_type === 'video') { %>
                        <div class="board-media-item board-media-item--video">
                          <video
                            class="board-video"
                            controls
                            playsinline
                            preload="metadata"
                            src="<%= m.file_path %>"
                          >
                            Your browser does not support video playback.
                          </video>
                        </div>
                      <% } else { %>
                        <a
                          class="board-media-item board-media-item--image"
                          href="<%= m.file_path %>"
                          data-lightbox="<%= m.file_path %>"
                          data-lightbox-caption="<%= post.title %>"
                        >
                          <img
                            src="<%= m.thumb_path || m.file_path %>"
                            alt="<%= m.original_filename || 'Family photo' %>"
                            loading="lazy"
                          />
                        </a>
                      <% } %>
                    <% }) %>
                  </div>
                <% } %>
              </article>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
