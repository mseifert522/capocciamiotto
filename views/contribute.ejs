<%- include('partials/header', { pageTitle: 'Contribute Photos' }) %>
<section class="section">
  <div class="container narrow">
    <header class="section-header">
      <p class="section-eyebrow">Help complete our album</p>
      <h2 class="section-title">Contribute Family Photos</h2>
      <div class="section-rule"></div>
      <p class="section-lead">Upload one photo or many. Works on phones, tablets, and computers. Family contributions are published right away for the whole family to see.</p>
    </header>

    <div class="invite">
      <p><strong><%= contributeCta %></strong></p>
      <p><%= contributeCta2 %></p>
      <div class="btn-row" style="margin-top:1rem">
        <a class="btn btn-secondary" href="/contribute/member">Add My Name to Family Members</a>
        <a class="btn btn-secondary" href="/voice-recordings">Listen to Family Voices</a>
        <a class="btn btn-outline" href="/contribute/story">Share a Story</a>
      </div>
    </div>

    <% if (typeof pinHolder !== 'undefined' && pinHolder) { %>
      <p style="margin-bottom:0.5rem;font-family:var(--font-ui);color:var(--green);font-weight:600">
        Contributing as: <%= pinHolder.assignedName %>
        · <a href="#" onclick="document.getElementById('clear-pin-form').submit();return false;" style="color:var(--burgundy)">Forget this browser</a>
      </p>
      <p class="hint" style="margin-bottom:1rem">
        You won’t have to enter the family PIN again on this browser for up to 90 days.
      </p>
      <form id="clear-pin-form" method="post" action="/contribute/pin/clear" style="display:none"></form>
    <% } %>

    <form class="form-card" action="/contribute/photos" method="post" enctype="multipart/form-data" id="contribute-photos-form">
      <div class="form-row">
        <label>Photographs * <span class="bulk-label-note">(bulk upload supported)</span></label>
        <div
          class="dropzone bulk-dropzone"
          data-bulk-upload
          data-bulk-max="50"
          data-bulk-accept="image"
          data-bulk-required="1"
        >
          <div class="bulk-dropzone-main" data-bulk-trigger>
            <strong>Drag &amp; drop many photos here</strong>
            <span class="hint">Or tap / click to choose from your camera roll or computer. Add more in batches — they stack until you publish.</span>
            <span class="bulk-dropzone-limits">JPEG, PNG, WebP, HEIC · up to 25MB each · up to 50 photos per upload</span>
          </div>
          <input
            id="photos-input"
            type="file"
            name="photos"
            accept="image/*,.heic,.heif"
            multiple
            required
            data-bulk-input
            style="position:absolute;left:-9999px;opacity:0;width:1px;height:1px"
          />
          <div class="bulk-toolbar">
            <button type="button" class="btn btn-secondary" data-bulk-add>Add more photos</button>
            <button type="button" class="btn btn-outline" data-bulk-clear hidden>Clear all</button>
          </div>
          <p class="bulk-count" data-bulk-count>No photos selected yet.</p>
          <div class="bulk-previews" data-bulk-previews aria-live="polite"></div>
        </div>
      </div>

      <div class="form-row two">
        <div>
          <label for="reunion_year">Reunion year</label>
          <select id="reunion_year" name="reunion_year">
            <option value="">Select year…</option>
            <% years.forEach(function(y) { %>
              <option value="<%= y.year %>" <%= String(prefillYear) === String(y.year) ? 'selected' : '' %>><%= y.year %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label for="family_branch">Family branch</label>
          <select id="family_branch" name="family_branch">
            <option value="both">Both Capoccia &amp; Miotto</option>
            <option value="Capoccia">Capoccia family</option>
            <option value="Miotto">Miotto family</option>
          </select>
        </div>
      </div>

      <div class="form-row two">
        <label class="checkbox"><input type="checkbox" name="year_approximate" value="1" /> Year is approximate</label>
        <label class="checkbox"><input type="checkbox" name="year_unknown" id="year_unknown" value="1" /> I do not know the year</label>
      </div>

      <div class="form-row">
        <label for="title">Title (optional)</label>
        <input type="text" id="title" name="title" maxlength="200" placeholder="Example: Picnic tables at the 1990 reunion" />
      </div>

      <div class="form-row">
        <label for="description">Description or memory</label>
        <textarea id="description" name="description" maxlength="4000" placeholder="Share what you remember about this moment…"></textarea>
      </div>

      <div class="form-row">
        <label>People in the photograph</label>
        <div class="people-fields" id="people-fields">
          <input type="text" name="person_name" maxlength="120" placeholder="Full name of a person in the photo" />
          <input type="text" name="person_name" maxlength="120" placeholder="Another person (optional)" />
        </div>
        <button type="button" class="btn btn-outline" id="add-person-field" style="margin-top:0.5rem">+ Add another name</button>
      </div>

      <div class="form-row two">
        <div>
          <label for="location">Location (if known)</label>
          <input type="text" id="location" name="location" maxlength="200" />
        </div>
        <div>
          <label for="photo_date">Date (if known)</label>
          <input type="text" id="photo_date" name="photo_date" maxlength="80" placeholder="Example: Summer 1985" />
        </div>
      </div>

      <div class="form-row two">
        <div>
          <label for="original_owner">Who originally owned or provided this photo?</label>
          <input type="text" id="original_owner" name="original_owner" maxlength="120" />
        </div>
        <div>
          <label for="photographer">Photographer (if known)</label>
          <input type="text" id="photographer" name="photographer" maxlength="120" />
        </div>
      </div>

      <div class="form-row two">
        <div>
          <label for="contributor_name">Your name *</label>
          <input type="text" id="contributor_name" name="contributor_name" required maxlength="120" value="<%= (typeof pinHolder !== 'undefined' && pinHolder && pinHolder.assignedName) ? pinHolder.assignedName : '' %>" />
        </div>
        <div>
          <label for="contributor_email">Your email (private)</label>
          <input type="email" id="contributor_email" name="contributor_email" maxlength="160" />
        </div>
      </div>

      <div class="form-row">
        <label for="contributor_phone">Your telephone (private, optional)</label>
        <input type="tel" id="contributor_phone" name="contributor_phone" maxlength="40" />
      </div>

      <div class="form-row">
        <label class="checkbox">
          <input type="checkbox" name="may_display_public" value="1" checked />
          This photograph may be displayed publicly on the family tribute website
        </label>
      </div>

      <div class="form-row">
        <label class="checkbox">
          <input type="checkbox" name="permission_confirmed" value="1" required />
          I confirm I have permission to upload and share this material, and that it does not violate anyone’s privacy.
        </label>
      </div>

      <button type="submit" class="btn btn-primary btn-block">Publish Photographs</button>
    </form>
  </div>
</section>
<%- include('partials/footer') %>
