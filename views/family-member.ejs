<%
  const isLeader = !!(member.is_patriarch || member.is_matriarch);
  const pageKind = isLeader ? "Tribute" : "Bio";
%>
<%- include('partials/header', { pageTitle: member.display_name + ' · ' + pageKind }) %>
<section class="section">
  <div class="container narrow">
    <article class="card">
      <div class="card-portrait member-portrait-wrap" style="max-height:380px">
        <% if (member.portrait_path) { %>
          <button
            type="button"
            class="portrait-lightbox-btn"
            data-lightbox="<%= member.portrait_path %>"
            data-lightbox-caption="<%= member.display_name %>"
            aria-label="View full photo of <%= member.display_name %>"
          >
            <img src="<%= member.portrait_path %>" alt="<%= member.display_name %>" />
          </button>
          <% if (canUploadPhoto) { %>
            <form class="portrait-add-overlay" method="post" action="/family-members/<%= member.id %>/portrait" enctype="multipart/form-data">
              <label class="btn btn-secondary portrait-add-btn">
                Change photo
                <input type="file" name="portrait" accept="image/jpeg,image/png,image/webp,image/gif" required hidden onchange="this.form.submit()" />
              </label>
            </form>
          <% } else { %>
            <a class="btn btn-secondary portrait-add-btn portrait-add-overlay" href="/contribute/pin?next=portrait&amp;member=<%= member.id %>">
              Add photo
            </a>
          <% } %>
        <% } else { %>
          <div class="placeholder-mark placeholder-with-upload">
            <span class="placeholder-label">Photo for <%= member.display_name %></span>
            <span class="placeholder-hint">Upload a portrait of this family member (separate from reunion photo uploads).</span>
            <% if (canUploadPhoto) { %>
              <form class="portrait-add-form" method="post" action="/family-members/<%= member.id %>/portrait" enctype="multipart/form-data">
                <label class="btn btn-primary portrait-add-btn">
                  Add portrait photo
                  <input type="file" name="portrait" accept="image/jpeg,image/png,image/webp,image/gif" required hidden onchange="this.form.submit()" />
                </label>
              </form>
            <% } else { %>
              <a class="btn btn-primary portrait-add-btn" href="/contribute/pin?next=portrait&amp;member=<%= member.id %>">
                Add portrait photo
              </a>
              <span class="placeholder-pin-note">Family PIN required to upload a portrait</span>
            <% } %>
          </div>
        <% } %>
      </div>
      <div class="card-body">
        <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-bottom:0.5rem">
          <span class="badge <%= member.family_branch === 'Capoccia' ? 'badge-capoccia' : (member.family_branch === 'Miotto' ? 'badge-miotto' : 'badge-both') %>"><%= member.family_branch %> family</span>
          <% if (member.is_patriarch) { %><span class="badge badge-both">Patriarch</span><% } %>
          <% if (member.is_matriarch) { %><span class="badge badge-both">Matriarch</span><% } %>
          <% if (!isLeader) { %><span class="badge badge-both">Family member</span><% } %>
        </div>
        <h3><%= member.display_name %></h3>
        <% if (member.maiden_name) { %>
          <p class="meta">née <%= member.maiden_name %></p>
        <% } %>
        <p class="meta"><%= member.role_in_family || 'Family member' %></p>
        <% if (member.birth_date_display || member.death_date_display) { %>
          <p style="font-family:var(--font-ui);color:var(--ink-muted);margin:0.35rem 0 0.75rem">
            <% if (member.birth_date_display && member.death_date_display) { %>
              <%= member.birth_date_display %> – <%= member.death_date_display %>
            <% } else if (member.birth_date_display) { %>
              <%= member.birth_date_display %>
            <% } else if (member.death_date_display) { %>
              <%= member.death_date_display %>
            <% } %>
          </p>
        <% } %>

        <div class="member-bio-block" style="margin-top:1.15rem">
          <h4 style="font-family:var(--font-display);font-size:1.35rem;color:var(--burgundy);margin:0 0 0.5rem">
            <%= isLeader ? "Family tribute" : "Bio" %>
          </h4>
          <% if (member.biography) { %>
            <% member.biography.split(/\n\n+/).forEach(function(para) { %>
              <p style="margin-top:0.85rem;line-height:1.75"><%= para %></p>
            <% }) %>
          <% } else if (!isLeader) { %>
            <p style="margin-top:0.5rem;color:var(--ink-muted);line-height:1.6">
              No bio yet. Family members can add one when they sign up, or share a memory below.
            </p>
          <% } %>
        </div>

        <% if (member.favorite_memories) { %>
          <p style="margin-top:1rem;font-style:italic;color:var(--ink-muted)"><%= member.favorite_memories %></p>
        <% } %>
        <% if (member.quotes) { %>
          <p style="margin-top:0.75rem"><em>“<%= member.quotes %>”</em></p>
        <% } %>

        <% if (recordings && recordings.length) { %>
          <div class="voice-section" style="margin-top:1.5rem">
            <h4 style="font-family:var(--font-display);font-size:1.35rem;color:var(--burgundy);margin-bottom:0.75rem">Voice &amp; stories</h4>
            <% recordings.forEach(function(r) { %>
              <div class="voice-card" style="margin-bottom:0.85rem">
                <p class="voice-meta" style="margin-bottom:0.35rem">
                  <strong><%= r.title || r.recording_type || 'Recording' %></strong>
                  <% if (r.recorded_year) { %> · <%= r.recorded_year %><% } %>
                </p>
                <% if (r.description) { %><p class="voice-desc"><%= r.description %></p><% } %>
                <audio class="voice-player" controls preload="none" src="<%= r.file_path %>"></audio>
              </div>
            <% }) %>
          </div>
        <% } %>

        <div class="btn-row" style="margin-top:1.25rem">
          <a class="btn btn-outline" href="/contribute/member">Add your name &amp; bio</a>
          <a class="btn btn-outline" href="/contribute/story">Share a memory</a>
          <a class="btn btn-outline" href="/contribute">Contribute reunion photos</a>
        </div>
      </div>
    </article>
  </div>
</section>
<%- include('partials/footer') %>
