<%- include('partials/header', { pageTitle: 'Family Members' }) %>
<section class="section">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">People in our family history</p>
      <h2 class="section-title">Family Members</h2>
      <div class="section-rule"></div>
      <p class="section-lead">
        Capoccia and Miotto are displayed as equal partners. Both branches are honored with the same care and space.
      </p>
    </header>

    <div class="family-branches">
      <div class="family-branch-col">
        <div class="family-branch-heading branch-capoccia">
          <span class="branch-flag" aria-hidden="true"></span>
          <h3>Capoccia Family</h3>
          <p><%= (membersCapoccia || []).length %> tribute<%= (membersCapoccia || []).length === 1 ? '' : 's' %></p>
        </div>
        <div class="card-grid card-grid-equal">
          <% (membersCapoccia || []).forEach(function(m) { %>
            <article class="card card-equal">
              <div class="card-portrait">
                <% if (m.portrait_path) { %>
                  <img src="<%= m.portrait_path %>" alt="<%= m.display_name %>" />
                <% } else { %>
                  <div class="placeholder-mark">Portrait placeholder<br />for <%= m.display_name %></div>
                <% } %>
              </div>
              <div class="card-body">
                <div class="card-badges">
                  <span class="badge badge-capoccia">Capoccia</span>
                  <% if (m.is_memorial) { %><span class="badge badge-memory">In loving memory</span><% } %>
                  <% if (m.is_patriarch) { %><span class="badge badge-both">Patriarch</span><% } %>
                  <% if (m.is_matriarch) { %><span class="badge badge-both">Matriarch</span><% } %>
                </div>
                <h3><%= m.display_name %></h3>
                <p class="meta"><%= m.role_in_family || 'Family member' %></p>
                <a class="btn btn-outline card-cta" href="/family-members/<%= m.id %>">Open profile</a>
              </div>
            </article>
          <% }) %>
        </div>
      </div>

      <div class="family-branch-col">
        <div class="family-branch-heading branch-miotto">
          <span class="branch-flag" aria-hidden="true"></span>
          <h3>Miotto Family</h3>
          <p><%= (membersMiotto || []).length %> tribute<%= (membersMiotto || []).length === 1 ? '' : 's' %></p>
        </div>
        <div class="card-grid card-grid-equal">
          <% (membersMiotto || []).forEach(function(m) { %>
            <article class="card card-equal">
              <div class="card-portrait">
                <% if (m.portrait_path) { %>
                  <img src="<%= m.portrait_path %>" alt="<%= m.display_name %>" />
                <% } else { %>
                  <div class="placeholder-mark">Portrait placeholder<br />for <%= m.display_name %></div>
                <% } %>
              </div>
              <div class="card-body">
                <div class="card-badges">
                  <span class="badge badge-miotto">Miotto</span>
                  <% if (m.is_memorial) { %><span class="badge badge-memory">In loving memory</span><% } %>
                  <% if (m.is_patriarch) { %><span class="badge badge-both">Patriarch</span><% } %>
                  <% if (m.is_matriarch) { %><span class="badge badge-both">Matriarch</span><% } %>
                </div>
                <h3><%= m.display_name %></h3>
                <p class="meta"><%= m.role_in_family || 'Family member' %></p>
                <a class="btn btn-outline card-cta" href="/family-members/<%= m.id %>">Open profile</a>
              </div>
            </article>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="empty" style="margin-top:2rem">
      <h3>More names will appear as the family contributes them.</h3>
      <p>Submit family information so we can add Capoccia and Miotto elders, parents, children, and cousins with equal care on both sides.</p>
      <a class="btn btn-primary" href="/contribute/story">Submit Family Information</a>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
