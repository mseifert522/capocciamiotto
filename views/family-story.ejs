<%- include('partials/header', { pageTitle: 'Our Family Story' }) %>
<%
  function findLeader(list, tests) {
    for (let i = 0; i < (list || []).length; i++) {
      const m = list[i];
      const full = (m.full_name || "");
      const pref = (m.preferred_name || "");
      const blob = (full + " " + pref).toLowerCase();
      if (tests.every(function (t) { return t.test(blob); })) return m;
    }
    return null;
  }
  const all = (typeof members !== "undefined" && members) ? members : [];
  const leaders = [
    { m: findLeader(all, [/george/, /capoccia/]), fallbackRole: "Capoccia Patriarch" },
    { m: findLeader(all, [/christine/, /capoccia/]), fallbackRole: "Capoccia Matriarch" },
    { m: findLeader(all, [/tony|anthony/, /capoccia/]), fallbackRole: "Honored Elder" },
    { m: findLeader(all, [/fran|frances/, /capoccia/]), fallbackRole: "Honored Elder" },
    { m: findLeader(all, [/mickey|amerigo/]), fallbackRole: "Miotto Patriarch" },
    { m: findLeader(all, [/anna/, /miotto/]), fallbackRole: "Miotto Matriarch" },
  ].filter(function (x) { return x && x.m; });

  function personName(m) {
    return m.display_name || m.preferred_name || m.full_name || "Family member";
  }
  function initial(s) {
    return String(s || "?").charAt(0).toUpperCase();
  }
%>

<section class="section fs-page">
  <div class="fs-wrap">
    <header class="section-header">
      <p class="section-eyebrow">Capoccia · Miotto</p>
      <h2 class="section-title">Our Family Story</h2>
      <div class="section-rule"></div>
    </header>

    <p class="fs-intro">
      The Capoccia and Miotto families share Italian heritage. Their reunion tradition began in <strong>1977</strong>
      and continues as a gift to every generation. The branches were joined when <strong>Anna M. Capoccia</strong>
      married <strong>Amerigo “Mickey” Miotto</strong>. Anna’s brothers, <strong>George</strong> and <strong>Tony Capoccia</strong>,
      remain central to that living connection.
    </p>

    <h3 class="fs-subhead">Our Patriarchs &amp; Matriarchs</h3>
    <div class="fs-grid">
      <% leaders.forEach(function(item) {
        const m = item.m;
        const name = personName(m);
        const role = m.role_in_family || item.fallbackRole;
      %>
        <article class="fs-card">
          <a class="fs-card-link" href="/family-members/<%= m.id %>">
            <div class="fs-card-photo">
              <% if (m.portrait_path) { %>
                <img src="<%= m.portrait_path %>" alt="<%= name %>" loading="lazy" />
              <% } else { %>
                <div class="fs-card-ph"><%= initial(name) %></div>
              <% } %>
            </div>
            <div class="fs-card-body">
              <h4 class="fs-card-name"><%= name %></h4>
              <p class="fs-card-role"><%= role %></p>
            </div>
          </a>
        </article>
      <% }) %>
    </div>

    <h3 class="fs-subhead">Our Family Tree</h3>
    <div class="fs-tree">
      <div class="fs-tree-root">
        <p class="fs-tree-label">Capoccia Parents</p>
        <p class="fs-tree-names">Costanzo &amp; Madeline</p>
      </div>
      <div class="fs-tree-stem" aria-hidden="true"></div>
      <div class="fs-tree-branches">
        <% if (typeof tree !== "undefined" && tree && tree.lines && tree.lines.length) { %>
          <% tree.lines.forEach(function(line) { %>
            <div class="fs-tree-branch">
              <div class="fs-tree-couple">
                <p class="fs-tree-label"><%= line.role %></p>
                <p class="fs-tree-names">
                  <% if (line.primary) { %>
                    <a href="/family-members/<%= line.primary.id %>"><%= line.primary.name %></a>
                  <% } %>
                  <% if (line.spouse) { %>
                    <span class="fs-tree-and">&amp;</span>
                    <a href="/family-members/<%= line.spouse.id %>"><%= line.spouse.name %></a>
                  <% } else if (!line.primary) { %>
                    <%= line.title %>
                  <% } %>
                </p>
              </div>
              <% if (line.children && line.children.length) { %>
                <ul class="fs-tree-kids">
                  <% line.children.forEach(function(c) { %>
                    <li>
                      <a href="/family-members/<%= c.id %>"><%= c.name %></a>
                      <% if (c.role) { %><span><%= c.role %></span><% } %>
                    </li>
                  <% }) %>
                </ul>
              <% } else { %>
                <p class="fs-tree-empty">Descendants will appear here as family names are added.</p>
              <% } %>
            </div>
          <% }) %>
        <% } else { %>
          <div class="fs-tree-branch">
            <div class="fs-tree-couple">
              <p class="fs-tree-label">Honored Elders</p>
              <p class="fs-tree-names">Tony &amp; Fran Capoccia</p>
            </div>
          </div>
          <div class="fs-tree-branch">
            <div class="fs-tree-couple">
              <p class="fs-tree-label">Capoccia Patriarch &amp; Matriarch</p>
              <p class="fs-tree-names">George &amp; Christine Capoccia</p>
            </div>
          </div>
          <div class="fs-tree-branch">
            <div class="fs-tree-couple">
              <p class="fs-tree-label">Miotto Matriarch &amp; Patriarch</p>
              <p class="fs-tree-names">Anna &amp; Mickey Miotto</p>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <div class="fs-actions">
      <a class="btn btn-primary" href="/family-tree">Open the Living Family Tree</a>
      <a class="btn btn-outline" href="/contribute/member">Add My Name to the Tree</a>
      <% if (typeof tree !== "undefined" && tree) { %>
        <p class="fs-count"><%= tree.memberCount %> family members on the tree<% if (tree.growingCount) { %> · growing as names are approved<% } %>.</p>
      <% } %>
    </div>

    <div class="empty" style="margin-top:2rem">
      <h3>Help us complete the next chapters.</h3>
      <p>Share names, photographs, dates, stories, documents, recipes, traditions, and memories of the Capoccia and Miotto families.</p>
      <a class="btn btn-secondary" href="/contribute/story">Help Tell Our Family Story</a>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
