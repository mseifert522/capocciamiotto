<%- include('partials/header', { pageTitle: 'Our Family Story' }) %>
<%
  function findOne(list, tests) {
    for (let i = 0; i < (list || []).length; i++) {
      const m = list[i];
      const blob = ((m.full_name || "") + " " + (m.preferred_name || "")).toLowerCase();
      if (tests.every(function (t) { return t.test(blob); })) return m;
    }
    return null;
  }
  const all = (typeof members !== "undefined" && members) ? members : [];
  const tony = findOne(all, [/tony|anthony/, /capoccia/]);
  const fran = findOne(all, [/fran|frances/, /capoccia/]);
  const george = findOne(all, [/george/, /capoccia/]);
  const christine = findOne(all, [/christine/, /capoccia/]);
  const anna = findOne(all, [/anna/, /miotto/]);
  const mickey = findOne(all, [/mickey|amerigo/]);

  // Correct order: each sibling with their spouse
  const couples = [
    {
      label: "Tony & Fran Capoccia",
      left: tony,
      right: fran,
      leftName: "Tony Capoccia",
      rightName: "Fran Capoccia",
      leftRole: "Family",
      rightRole: "Family",
    },
    {
      label: "Capoccia Patriarch & Matriarch",
      left: george,
      right: christine,
      leftName: "George Capoccia",
      rightName: "Christine Capoccia",
      leftRole: "Capoccia Patriarch",
      rightRole: "Capoccia Matriarch",
    },
    {
      label: "Miotto Matriarch & Patriarch",
      left: anna,
      right: mickey,
      leftName: "Anna Miotto",
      rightName: "Mickey Miotto",
      leftRole: "Miotto Matriarch",
      rightRole: "Miotto Patriarch",
    },
  ];

  function initial(s) {
    return String(s || "?").charAt(0).toUpperCase();
  }
  function roleOf(m, fallback) {
    return (m && m.role_in_family) ? m.role_in_family : fallback;
  }
%>

<section class="section fs-page">
  <div class="fs-wrap">
    <header class="section-header">
      <p class="section-eyebrow">Capoccia · Miotto</p>
      <h2 class="section-title">Our Family Story</h2>
      <div class="section-rule"></div>
    </header>

    <p class="fs-intro">
      The Capoccia and Miotto families share Italian heritage. Their reunion tradition began in <strong>1977</strong>
      and continues as a gift to every generation. The Capoccia siblings — <strong>Tony</strong>, <strong>George</strong>, and <strong>Anna</strong> —
      with their spouses <strong>Fran</strong>, <strong>Christine</strong>, and <strong>Mickey</strong>, form the heart of this living tribute.
    </p>

    <h3 class="fs-subhead">Our Patriarchs &amp; Matriarchs</h3>
    <p class="fs-order-note">Tony &amp; Fran · George &amp; Christine · Anna &amp; Mickey</p>

    <div class="couple-gallery couple-gallery--story">
      <% couples.forEach(function(c) { %>
        <article class="couple-unit">
          <p class="couple-unit-label"><%= c.label %></p>
          <div class="couple-pair">
            <% if (c.left) { %>
              <a class="couple-person" href="/family-members/<%= c.left.id %>">
                <div class="couple-photo">
                  <% if (c.left.portrait_path) { %>
                    <img src="<%= c.left.portrait_path %>" alt="<%= c.leftName %>" loading="lazy" />
                  <% } else { %>
                    <div class="couple-ph" aria-hidden="true"><%= initial(c.leftName) %></div>
                  <% } %>
                </div>
                <h3><%= c.leftName %></h3>
                <p><%= roleOf(c.left, c.leftRole) %></p>
              </a>
            <% } %>

            <div class="couple-join" aria-hidden="true">
              <span class="couple-heart">&amp;</span>
            </div>

            <% if (c.right) { %>
              <a class="couple-person" href="/family-members/<%= c.right.id %>">
                <div class="couple-photo">
                  <% if (c.right.portrait_path) { %>
                    <img src="<%= c.right.portrait_path %>" alt="<%= c.rightName %>" loading="lazy" />
                  <% } else { %>
                    <div class="couple-ph" aria-hidden="true"><%= initial(c.rightName) %></div>
                  <% } %>
                </div>
                <h3><%= c.rightName %></h3>
                <p><%= roleOf(c.right, c.rightRole) %></p>
              </a>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>

    <h3 class="fs-subhead" style="margin-top:2.75rem">Our Family Tree</h3>
    <div class="fs-tree">
      <div class="fs-tree-root">
        <p class="fs-tree-label">Capoccia Parents</p>
        <p class="fs-tree-names">Costanzo &amp; Madeline</p>
      </div>
      <div class="fs-tree-stem" aria-hidden="true"></div>
      <div class="fs-tree-branches">
        <% 
          // Force correct branch order: Tony line, George line, Anna line
          const lineOrder = ["tony", "george", "anna"];
          const linesByKey = {};
          if (typeof tree !== "undefined" && tree && tree.lines) {
            tree.lines.forEach(function(l) { linesByKey[l.key] = l; });
          }
          const orderedLines = lineOrder.map(function(k) {
            if (linesByKey[k]) return linesByKey[k];
            if (k === "tony") return { key: "tony", role: "Tony & Fran Capoccia", title: "Tony & Fran Capoccia", primary: tony ? { id: tony.id, name: "Tony Capoccia" } : null, spouse: fran ? { id: fran.id, name: "Fran Capoccia" } : null, children: [] };
            if (k === "george") return { key: "george", role: "Capoccia Patriarch & Matriarch", title: "George & Christine", primary: george ? { id: george.id, name: "George Capoccia" } : null, spouse: christine ? { id: christine.id, name: "Christine Capoccia" } : null, children: [] };
            return { key: "anna", role: "Miotto Matriarch & Patriarch", title: "Anna & Mickey", primary: anna ? { id: anna.id, name: "Anna Miotto" } : null, spouse: mickey ? { id: mickey.id, name: "Mickey Miotto" } : null, children: [] };
          });
        %>
        <% orderedLines.forEach(function(line) { %>
          <div class="fs-tree-branch">
            <div class="fs-tree-couple">
              <p class="fs-tree-label"><%= line.role %></p>
              <p class="fs-tree-names">
                <% if (line.primary) { %>
                  <a href="/family-members/<%= line.primary.id %>"><%= line.primary.name %></a>
                <% } %>
                <% if (line.spouse) { %>
                  <span class="fs-tree-and">&amp;</span>
                  <a href="/family-members/<%= line.spouse.id %>"><%= line.spouse.name %></a>
                <% } else if (!line.primary) { %>
                  <%= line.title %>
                <% } %>
              </p>
            </div>
            <% if (line.children && line.children.length) { %>
              <ul class="fs-tree-kids">
                <% line.children.forEach(function(c) { %>
                  <li>
                    <a href="/family-members/<%= c.id %>"><%= c.name %></a>
                    <% if (c.role) { %><span><%= c.role %></span><% } %>
                  </li>
                <% }) %>
              </ul>
            <% } else { %>
              <p class="fs-tree-empty">Descendants will appear here as family names are added.</p>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>

    <div class="fs-actions">
      <a class="btn btn-primary" href="/family-tree">Open the Living Family Tree</a>
      <a class="btn btn-outline" href="/contribute/member">Add My Name to the Tree</a>
      <% if (typeof tree !== "undefined" && tree) { %>
        <p class="fs-count"><%= tree.memberCount %> family members on the tree<% if (tree.growingCount) { %> · growing as names are approved<% } %>.</p>
      <% } %>
    </div>

    <div class="empty" style="margin-top:2rem">
      <h3>Help us complete the next chapters.</h3>
      <p>Share names, photographs, dates, stories, documents, recipes, traditions, and memories of the Capoccia and Miotto families.</p>
      <a class="btn btn-secondary" href="/contribute/story">Help Tell Our Family Story</a>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
