<%- include('partials/header', { pageTitle: 'Family Guidelines' }) %>
<section class="section"><div class="container narrow">
  <h2 class="section-title" style="margin-bottom:1rem">Family Guidelines</h2>
  <ul style="list-style:disc;padding-left:1.25rem;color:var(--ink-soft)">
    <li style="margin-bottom:0.5rem">Speak with warmth and respect for all Capoccia and Miotto family members.</li>
    <li style="margin-bottom:0.5rem">Share only photographs and stories you have permission to share.</li>
    <li style="margin-bottom:0.5rem">Do not invent names, dates, or relationships.</li>
    <li style="margin-bottom:0.5rem">Do not post private contact details of other people.</li>
    <li style="margin-bottom:0.5rem">Memorial content should be gentle and dignified.</li>
    <li style="margin-bottom:0.5rem">Administrators may edit, move, or remove content to protect the family archive.</li>
  </ul>
</div></section>
<%- include('partials/footer') %>
