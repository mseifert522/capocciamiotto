<%- include('partials/header', { pageTitle: 'Home' }) %>

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-flag" aria-label="Italian flag" title="Italian heritage">
      <i></i><i></i><i></i>
    </div>
    <p class="hero-kicker">A living family legacy</p>
    <h1>The Capoccia–Miotto Family Reunion Tribute</h1>
    <p class="hero-sub">Celebrating Family, Tradition, and Memories Since 1977</p>
    <p class="hero-lead">
      Welcome to the Capoccia–Miotto Family Reunion Tribute—a living collection of the people, photographs, stories, and traditions that have brought our families together since 1977. This tribute belongs to every member of the Capoccia and Miotto families. Together, we can preserve our history and continue adding to it for generations to come.
    </p>
    <div class="btn-row">
      <a class="btn btn-primary" href="/reunion-timeline">Explore the Reunions</a>
      <a class="btn btn-outline" href="/contribute">Contribute Family Photos</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="invite">
      <p><strong><%= contributeCta %></strong></p>
      <p><%= contributeCta2 %></p>
      <div class="btn-row" style="margin-top:1rem">
        <a class="btn btn-primary" href="/contribute">Contribute Family Photos</a>
        <a class="btn btn-secondary" href="/contribute/request-pin">Request Family PIN #</a>
        <a class="btn btn-outline" href="/contribute/member">Add My Name</a>
        <a class="btn btn-outline" href="/voice-recordings">Listen to Family Voices</a>
        <a class="btn btn-outline" href="/contribute/story">Help Tell Our Family Story</a>
      </div>
    </div>
  </div>
</section>

<section class="section section-alt" id="family-tribute">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">Capoccia · Miotto</p>
      <h2 class="section-title">Our Family Leaders</h2>
      <div class="section-rule"></div>
      <p class="section-lead">Anna &amp; Mickey · Tony &amp; Fran · George &amp; Christine</p>
    </header>

    <%- include('partials/family-tribute-grid') %>

    <header class="section-header" style="margin-top:3rem" id="family-members">
      <p class="section-eyebrow">Our growing family</p>
      <h2 class="section-title">Family Members</h2>
      <div class="section-rule"></div>
      <p class="section-lead">Every Capoccia and Miotto family member on our living tribute.</p>
    </header>

    <% if (typeof allMembers !== 'undefined' && allMembers && allMembers.length) { %>
      <div class="member-grid" role="list">
        <% allMembers.forEach(function(m) { %>
          <article class="member-card" role="listitem">
            <div class="member-card-photo">
              <% if (m.portrait_path) { %>
                <button
                  type="button"
                  class="portrait-lightbox-btn member-card-photo-btn"
                  data-lightbox="<%= m.portrait_path %>"
                  data-lightbox-caption="<%= m.display_name %>"
                  aria-label="View full photo of <%= m.display_name %>"
                >
                  <img src="<%= m.portrait_path %>" alt="<%= m.display_name %>" loading="lazy" />
                </button>
              <% } else { %>
                <div class="member-card-placeholder" aria-hidden="true">
                  <span><%= (m.display_name || "?").charAt(0) %></span>
                </div>
              <% } %>
            </div>
            <div class="member-card-body">
              <h3><%= m.display_name %></h3>
              <% if (m.role_in_family) { %>
                <p class="member-card-role"><%= m.role_in_family %></p>
              <% } %>
              <% if (m.family_branch) { %>
                <p class="member-card-branch"><%= m.family_branch === 'both' ? 'Capoccia · Miotto' : m.family_branch %></p>
              <% } %>
              <a class="btn btn-outline member-card-cta" href="/family-members/<%= m.id %>">View full tribute</a>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty" style="margin-top:0.5rem">
        <h3>Add your name to our family tribute</h3>
        <a class="btn btn-primary" href="/contribute/member">Add My Name</a>
      </div>
    <% } %>
  </div>
</section>

<section class="section">
  <div class="container narrow" style="text-align:center">
    <header class="section-header">
      <p class="section-eyebrow">Italian roots · American reunions</p>
      <h2 class="section-title">Our Family History</h2>
      <div class="section-rule"></div>
    </header>
    <p class="section-lead">
      The Capoccia and Miotto families share Italian heritage and a reunion tradition that began in <strong>1977</strong>.
    </p>
    <div class="empty" style="margin-top:1.5rem">
      <h3>Help tell our family story</h3>
      <a class="btn btn-secondary" href="/contribute/story">Share a Memory</a>
    </div>
  </div>
</section>

<section class="section section-dark">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">Since 1977</p>
      <h2 class="section-title">Reunion Timeline</h2>
      <div class="section-rule"></div>
    </header>
    <div style="text-align:center">
      <a class="btn btn-gold" href="/reunion-timeline">Open the Full Timeline</a>
    </div>
  </div>
</section>

<section class="section section-alt">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">Family gathering place</p>
      <h2 class="section-title">Community Board</h2>
      <div class="section-rule"></div>
    </header>
    <% if (pinned.length) { %>
      <div class="board-list" style="max-width:760px;margin:0 auto">
        <% pinned.forEach(function(post) { %>
          <article class="board-post pinned">
            <h3><%= post.title %></h3>
            <p class="board-meta">Pinned · <%= post.author_name || 'Family' %></p>
            <p><%= post.body %></p>
          </article>
        <% }) %>
      </div>
    <% } %>
    <div style="text-align:center;margin-top:1.5rem">
      <a class="btn btn-outline" href="/community-board">Visit the Community Board</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
