<%- include('partials/header', { pageTitle: 'In Loving Memory' }) %>
<section class="section">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">Capoccia · Miotto</p>
      <h2 class="section-title">In Loving Memory</h2>
      <div class="section-rule"></div>
    </header>

    <% if (members && members.length) { %>
      <div class="tribute-grid" role="list">
        <% members.forEach(function(m) { %>
          <article class="tribute-card" role="listitem">
            <div class="tribute-card-photo">
              <% if (m.portrait_path) { %>
                <button
                  type="button"
                  class="portrait-lightbox-btn tribute-card-photo-btn"
                  data-lightbox="<%= m.portrait_path %>"
                  data-lightbox-caption="<%= m.display_name %>"
                  aria-label="View full photo of <%= m.display_name %>"
                >
                  <img src="<%= m.portrait_path %>" alt="<%= m.display_name %>" loading="lazy" />
                </button>
              <% } else { %>
                <div class="tribute-card-photo-placeholder" aria-hidden="true">
                  <span><%= (m.display_name || "?").charAt(0) %></span>
                </div>
              <% } %>
            </div>
            <div class="tribute-card-body">
              <h3 class="tribute-card-name"><%= m.display_name %></h3>
              <p class="tribute-card-role"><%= m.role_in_family || "" %></p>
              <% if (m.birth_date_display || m.death_date_display) { %>
                <p class="tribute-card-dates">
                  <% if (m.birth_date_display && m.death_date_display) { %>
                    <%= m.birth_date_display %> – <%= m.death_date_display %>
                  <% } else if (m.death_date_display) { %>
                    <%= m.death_date_display %>
                  <% } else { %>
                    <%= m.birth_date_display %>
                  <% } %>
                </p>
              <% } %>
              <% if (m.biography) { %>
                <div class="tribute-card-bio">
                  <% m.biography.split(/\n\n+/).forEach(function(para) { %>
                    <p><%= para %></p>
                  <% }) %>
                </div>
              <% } %>
              <a class="btn btn-outline tribute-card-cta" href="/family-members/<%= m.id %>">View full tribute</a>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty">
        <h3>Memorial tributes</h3>
        <a class="btn btn-outline" href="/contact">Contact Family Administrators</a>
      </div>
    <% } %>
  </div>
</section>
<%- include('partials/footer') %>
