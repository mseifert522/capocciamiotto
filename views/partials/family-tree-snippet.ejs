<%
  function findMemberId(list, tests) {
    const members = list || [];
    for (let i = 0; i < members.length; i++) {
      const m = members[i];
      const blob = ((m.full_name || "") + " " + (m.preferred_name || "")).toLowerCase();
      if (tests.every((t) => t.test(blob))) return m.id;
    }
    return null;
  }
  const all = typeof members !== "undefined" ? members : [];
  const idTony = findMemberId(all, [/tony|anthony/, /capoccia/]);
  const idFran = findMemberId(all, [/fran|frances/, /capoccia/]);
  const idGeorge = findMemberId(all, [/george/, /capoccia/]);
  const idChristine = findMemberId(all, [/christine/, /capoccia/]);
  const idAnna = findMemberId(all, [/anna/, /miotto/]);
  const idMickey = findMemberId(all, [/mickey|amerigo/, /miotto/]);

  function hrefFor(id) {
    return id ? "/family-members/" + id : null;
  }

  function childCount(key) {
    if (typeof tree === "undefined" || !tree || !tree.lines) return 0;
    const line = tree.lines.find(function (l) { return l.key === key; });
    return line && line.children ? line.children.length : 0;
  }

  const tonyKids = childCount("tony");
  const georgeKids = childCount("george");
  const annaKids = childCount("anna");
%>

<div class="fts">
  <div class="fts-header">
    <p class="fts-eyebrow">Capoccia · Miotto</p>
    <h3 class="fts-title">Family Tree Snippet</h3>
    <div class="fts-rule"></div>
  </div>

  <div class="fts-root">
    <p class="fts-label">Capoccia Parents</p>
    <p class="fts-names">Costanzo &amp; Maddalena (Madeline) Capoccia</p>
  </div>

  <div class="fts-stem" aria-hidden="true"></div>

  <div class="fts-branches">
    <article class="fts-card">
      <p class="fts-role">Tony &amp; Fran Capoccia</p>
      <p class="fts-names">
        <% if (hrefFor(idTony)) { %><a href="<%= hrefFor(idTony) %>">Tony</a><% } else { %><span>Tony</span><% } %>
        <span class="fts-muted">(m.
          <% if (hrefFor(idFran)) { %><a href="<%= hrefFor(idFran) %>">Fran Babich</a><% } else { %><span>Fran Babich</span><% } %>)
        </span>
      </p>
      <% if (tonyKids) { %><p class="fts-meta"><%= tonyKids %> family under this line</p><% } %>
    </article>

    <article class="fts-card fts-card--accent">
      <p class="fts-role">Capoccia Patriarch &amp; Matriarch</p>
      <p class="fts-names">
        <% if (hrefFor(idGeorge)) { %><a href="<%= hrefFor(idGeorge) %>">George</a><% } else { %><span>George</span><% } %>
        <span class="fts-muted">(m.
          <% if (hrefFor(idChristine)) { %><a href="<%= hrefFor(idChristine) %>">Christine</a><% } else { %><span>Christine</span><% } %>)
        </span>
      </p>
      <% if (georgeKids) { %><p class="fts-meta"><%= georgeKids %> family under this line</p><% } %>
    </article>

    <article class="fts-card">
      <p class="fts-role">Miotto Matriarch &amp; Patriarch</p>
      <p class="fts-names">
        <% if (hrefFor(idAnna)) { %><a href="<%= hrefFor(idAnna) %>">Anna</a><% } else { %><span>Anna</span><% } %>
        <span class="fts-muted">(m.
          <% if (hrefFor(idMickey)) { %><a href="<%= hrefFor(idMickey) %>">Mickey Miotto</a><% } else { %><span>Mickey Miotto</span><% } %>)
        </span>
      </p>
      <p class="fts-meta">Capoccia · Miotto branch<% if (annaKids) { %> · <%= annaKids %> family listed<% } %></p>
    </article>
  </div>
</div>
