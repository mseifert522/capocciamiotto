<%
  /* Order: Capoccia siblings first (Tony, George, Anna), then spouses (Fran, Christine, Mickey) */
  function tributeLeaders(list) {
    const rank = (m) => {
      const full = m.full_name || "";
      const n = (full + " " + (m.preferred_name || "")).trim();
      if (/Tony|Anthony/i.test(full) && /Capoccia/i.test(full)) return 1;
      if (/George/i.test(n) && /Capoccia/i.test(n)) return 2;
      if (/Anna/i.test(n) && /Miotto/i.test(n)) return 3;
      if (/Frances|^Fran\b/i.test(full) && /Capoccia/i.test(full)) return 4;
      if (/Christine/i.test(n) && /Capoccia/i.test(n)) return 5;
      if (/Mickey|Amerigo/i.test(n)) return 6;
      return 0;
    };
    return (list || [])
      .filter((m) => rank(m) > 0)
      .slice()
      .sort((a, b) => rank(a) - rank(b));
  }
  const leaders = tributeLeaders(typeof members !== "undefined" ? members : []);
  const siblings = leaders.filter(function (m, i) { return i < 3; });
  const spouses = leaders.filter(function (m, i) { return i >= 3; });

  function shortName(m) {
    const n = m.display_name || m.preferred_name || m.full_name || "";
    // Prefer familiar first names for the compact home display
    if (/Tony|Anthony/i.test(n)) return "Tony Capoccia";
    if (/George/i.test(n)) return "George Capoccia";
    if (/Anna/i.test(n)) return "Anna Miotto";
    if (/Fran|Frances/i.test(n)) return "Fran Capoccia";
    if (/Christine/i.test(n)) return "Christine Capoccia";
    if (/Mickey|Amerigo/i.test(n)) return "Mickey Miotto";
    return n;
  }
%>

<div class="home-leaders" role="list">
  <% if (siblings.length) { %>
    <p class="home-leaders-label">The Capoccia siblings</p>
    <div class="home-leaders-row home-leaders-row--siblings">
      <% siblings.forEach(function(m) { %>
        <article class="home-leader-card" role="listitem">
          <a class="home-leader-link" href="/family-members/<%= m.id %>">
            <div class="home-leader-photo">
              <% if (m.portrait_path) { %>
                <img src="<%= m.portrait_path %>" alt="<%= m.display_name %>" loading="lazy" />
              <% } else { %>
                <div class="home-leader-ph" aria-hidden="true"><%= shortName(m).charAt(0) %></div>
              <% } %>
            </div>
            <div class="home-leader-body">
              <h3><%= shortName(m) %></h3>
              <p><%= m.role_in_family || "Family leader" %></p>
              <span class="home-leader-cta">View tribute →</span>
            </div>
          </a>
        </article>
      <% }) %>
    </div>
  <% } %>

  <% if (spouses.length) { %>
    <p class="home-leaders-label home-leaders-label--spouses">With their spouses</p>
    <div class="home-leaders-row home-leaders-row--spouses">
      <% spouses.forEach(function(m) { %>
        <article class="home-leader-card home-leader-card--spouse" role="listitem">
          <a class="home-leader-link" href="/family-members/<%= m.id %>">
            <div class="home-leader-photo">
              <% if (m.portrait_path) { %>
                <img src="<%= m.portrait_path %>" alt="<%= m.display_name %>" loading="lazy" />
              <% } else { %>
                <div class="home-leader-ph" aria-hidden="true"><%= shortName(m).charAt(0) %></div>
              <% } %>
            </div>
            <div class="home-leader-body">
              <h3><%= shortName(m) %></h3>
              <p><%= m.role_in_family || "Family leader" %></p>
              <span class="home-leader-cta">View tribute →</span>
            </div>
          </a>
        </article>
      <% }) %>
    </div>
  <% } %>
</div>
