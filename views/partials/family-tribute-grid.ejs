<%
  /* Couple pairs in order: Anna+Mickey, Tony+Fran, George+Christine */
  function findOne(list, tests) {
    for (let i = 0; i < (list || []).length; i++) {
      const m = list[i];
      const full = m.full_name || "";
      const blob = (full + " " + (m.preferred_name || "")).toLowerCase();
      if (tests.every(function (t) { return t.test(blob); })) return m;
    }
    return null;
  }
  const all = typeof members !== "undefined" ? members : [];
  const tony = findOne(all, [/tony|anthony/, /capoccia/]);
  const fran = findOne(all, [/fran|frances/, /capoccia/]);
  const george = findOne(all, [/george/, /capoccia/]);
  const christine = findOne(all, [/christine/, /capoccia/]);
  const anna = findOne(all, [/anna/, /miotto/]);
  const mickey = findOne(all, [/mickey|amerigo/]);

  const couples = [
    {
      key: "anna",
      label: "Miotto Matriarch & Patriarch",
      person: anna,
      spouse: mickey,
      personShort: "Anna Miotto",
      spouseShort: "Mickey Miotto",
    },
    {
      key: "tony",
      label: "Capoccia Patriarch & Matriarch",
      person: tony,
      spouse: fran,
      personShort: "Tony Capoccia",
      spouseShort: "Fran Capoccia",
    },
    {
      key: "george",
      label: "Capoccia Patriarch & Matriarch",
      person: george,
      spouse: christine,
      personShort: "George Capoccia",
      spouseShort: "Christine Capoccia",
    },
  ];

  function displayOf(m, fallback) {
    if (!m) return fallback;
    return m.display_name || m.preferred_name || m.full_name || fallback;
  }
  function initial(s) {
    return String(s || "?").charAt(0).toUpperCase();
  }
%>

<div class="couple-gallery" role="list">
  <% couples.forEach(function(c, idx) { %>
    <article class="couple-unit" role="listitem">
      <p class="couple-unit-label"><%= c.label %></p>
      <div class="couple-pair">
        <% if (c.person) { %>
          <div class="couple-person">
            <div class="couple-photo">
              <% if (c.person.portrait_path) { %>
                <button
                  type="button"
                  class="couple-photo-btn"
                  data-lightbox="<%= c.person.portrait_path %>"
                  data-lightbox-caption="<%= displayOf(c.person, c.personShort) %>"
                  aria-label="View full photo of <%= displayOf(c.person, c.personShort) %>"
                >
                  <img src="<%= c.person.portrait_path %>" alt="<%= displayOf(c.person, c.personShort) %>" loading="lazy" />
                </button>
              <% } else { %>
                <div class="couple-ph" aria-hidden="true"><%= initial(c.personShort) %></div>
              <% } %>
            </div>
            <h3><a href="/family-members/<%= c.person.id %>"><%= c.personShort %></a></h3>
            <p><%= c.person.role_in_family || "Family leader" %></p>
          </div>
        <% } %>

        <div class="couple-join" aria-hidden="true">
          <span class="couple-heart">&amp;</span>
        </div>

        <% if (c.spouse) { %>
          <div class="couple-person">
            <div class="couple-photo">
              <% if (c.spouse.portrait_path) { %>
                <button
                  type="button"
                  class="couple-photo-btn"
                  data-lightbox="<%= c.spouse.portrait_path %>"
                  data-lightbox-caption="<%= displayOf(c.spouse, c.spouseShort) %>"
                  aria-label="View full photo of <%= displayOf(c.spouse, c.spouseShort) %>"
                >
                  <img src="<%= c.spouse.portrait_path %>" alt="<%= displayOf(c.spouse, c.spouseShort) %>" loading="lazy" />
                </button>
              <% } else { %>
                <div class="couple-ph" aria-hidden="true"><%= initial(c.spouseShort) %></div>
              <% } %>
            </div>
            <h3><a href="/family-members/<%= c.spouse.id %>"><%= c.spouseShort %></a></h3>
            <p><%= c.spouse.role_in_family || "Family leader" %></p>
          </div>
        <% } %>
      </div>
      <div class="couple-actions">
        <% if (c.person) { %>
          <a class="btn btn-outline couple-cta" href="/family-members/<%= c.person.id %>">View full tribute</a>
        <% } %>
        <% if (c.spouse) { %>
          <a class="btn btn-outline couple-cta" href="/family-members/<%= c.spouse.id %>">View full tribute</a>
        <% } %>
      </div>
    </article>
  <% }) %>
</div>
