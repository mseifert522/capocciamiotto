<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#6b1f2a" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' · ' : '' %><%= siteName %></title>
  <meta name="description" content="A living Capoccia–Miotto family reunion archive celebrating family, tradition, and memories since 1977." />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Source+Sans+3:wght@400;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/site.css?v=20260717f" />
</head>
<body class="<%= (typeof isLoggedIn !== 'undefined' && isLoggedIn) ? 'is-signed-in' : '' %>">
  <div class="tricolor" aria-hidden="true"></div>
  <header class="site-header<%= (typeof isLoggedIn !== 'undefined' && isLoggedIn) ? ' site-header--signed-in' : '' %>">
    <div class="container nav">
      <button class="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="main-nav">
        <span></span><span></span><span></span>
      </button>

      <nav class="nav-links" id="main-nav" aria-label="Main">
        <a href="/" class="<%= path === '/' ? 'active' : '' %>"<%= path === '/' ? ' aria-current="page"' : '' %>><span class="nav-text">Home</span></a>
        <a href="/our-family-story" class="<%= path.startsWith('/our-family') ? 'active' : '' %>"<%= path.startsWith('/our-family') ? ' aria-current="page"' : '' %>><span class="nav-text nav-text--long">Our Family Story</span><span class="nav-text nav-text--short" aria-hidden="true">Family Story</span></a>
        <a href="/reunion-timeline" class="<%= (path.startsWith('/reunion') || path === '/reunion-timeline') ? 'active' : '' %>"<%= (path.startsWith('/reunion') || path === '/reunion-timeline') ? ' aria-current="page"' : '' %>><span class="nav-text nav-text--long">Reunion Timeline</span><span class="nav-text nav-text--short" aria-hidden="true">Timeline</span></a>
        <a href="/photo-archive" class="<%= path.startsWith('/photo') ? 'active' : '' %>"<%= path.startsWith('/photo') ? ' aria-current="page"' : '' %>><span class="nav-text nav-text--long">Photo Archive</span><span class="nav-text nav-text--short" aria-hidden="true">Photos</span></a>
        <a href="/family-members" class="<%= path.startsWith('/family-members') ? 'active' : '' %>"<%= path.startsWith('/family-members') ? ' aria-current="page"' : '' %>><span class="nav-text nav-text--long">Family Members</span><span class="nav-text nav-text--short" aria-hidden="true">Members</span></a>
        <a href="/family-tree" class="<%= path.startsWith('/family-tree') ? 'active' : '' %>"<%= path.startsWith('/family-tree') ? ' aria-current="page"' : '' %>><span class="nav-text nav-text--long">Family Tree</span><span class="nav-text nav-text--short" aria-hidden="true">Tree</span></a>
        <a href="/community-board" class="<%= path.startsWith('/community') ? 'active' : '' %>"<%= path.startsWith('/community') ? ' aria-current="page"' : '' %>><span class="nav-text nav-text--long">Community Board</span><span class="nav-text nav-text--short" aria-hidden="true">Board</span></a>
        <a href="/voice-recordings" class="<%= path.startsWith('/voice') ? 'active' : '' %>"<%= path.startsWith('/voice') ? ' aria-current="page"' : '' %>><span class="nav-text">Listen</span></a>
        <a href="/in-loving-memory" class="<%= path.startsWith('/in-loving') ? 'active' : '' %>"<%= path.startsWith('/in-loving') ? ' aria-current="page"' : '' %>><span class="nav-text nav-text--long">In Loving Memory</span><span class="nav-text nav-text--short" aria-hidden="true">Memory</span></a>
        <a href="/upcoming-reunion" class="<%= path.startsWith('/upcoming') ? 'active' : '' %>"<%= path.startsWith('/upcoming') ? ' aria-current="page"' : '' %>><span class="nav-text nav-text--long">Upcoming Reunion</span><span class="nav-text nav-text--short" aria-hidden="true">Upcoming</span></a>
        <a href="/about" class="<%= path.startsWith('/about') ? 'active' : '' %>"<%= path.startsWith('/about') ? ' aria-current="page"' : '' %>><span class="nav-text">About</span></a>
        <!-- Contribute also in mobile drawer -->
        <a href="/contribute" class="nav-cta nav-cta--in-menu<%= path.startsWith('/contribute') ? ' active' : '' %>"<%= path.startsWith('/contribute') ? ' aria-current="page"' : '' %>><span class="nav-text">Contribute</span></a>
      </nav>

      <div class="nav-actions">
        <a href="/contribute" class="nav-cta nav-cta--bar<%= path.startsWith('/contribute') ? ' active' : '' %>"<%= path.startsWith('/contribute') ? ' aria-current="page"' : '' %>>Contribute</a>
        <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
          <form class="header-logout" method="post" action="/logout" title="Log out">
            <input type="hidden" name="return_to" value="<%= path || '/' %>" />
            <button type="submit" class="header-logout-btn">Log out</button>
          </form>
        <% } %>
      </div>
    </div>
  </header>
  <main>
    <% if (flash) { %>
      <div class="container" style="padding-top:1rem">
        <div class="flash flash-<%= flash.type %>"><%= flash.message %></div>
      </div>
    <% } %>
