<%
  /* Shared family member card for home + family-members list */
  const role = String(m.role_in_family || "");
  const nameBlob = String(m.full_name || "") + " " + String(m.preferred_name || "");
  // Only the six patriarch/matriarch leaders get "View full tribute"
  // (exclude younger Anthony Capoccia, son of David, etc.)
  const isLeader = !!(
    m.is_patriarch ||
    m.is_matriarch ||
    /patriarch|matriarch/i.test(role) ||
    (/anna/i.test(nameBlob) && /miotto/i.test(nameBlob)) ||
    (/mickey|amerigo/i.test(nameBlob) && /miotto/i.test(nameBlob)) ||
    (/(tony|anthony)/i.test(nameBlob) && /capoccia/i.test(nameBlob) && /joseph|tony|patriarch/i.test(nameBlob + " " + role)) ||
    (/(fran|frances)/i.test(nameBlob) && /capoccia/i.test(nameBlob)) ||
    (/^george\b/i.test(String(m.full_name || m.preferred_name || "").trim()) && /capoccia/i.test(nameBlob) && !/son of/i.test(role)) ||
    (/christine/i.test(nameBlob) && /capoccia/i.test(nameBlob) && !/son of|daughter of/i.test(role))
  );
  const ctaLabel = isLeader ? "View full tribute" : "View Bio";
  const ctaHref = "/family-members/" + m.id;
%>
<article class="member-card" role="listitem">
  <%/* Inline styles force edge-to-edge fill even if an old CSS file is cached */%>
  <div class="member-card-photo" style="aspect-ratio:1/1;position:relative;overflow:hidden;padding:0;margin:0;line-height:0;min-height:180px;">
    <% if (m.portrait_path) { %>
      <button
        type="button"
        class="portrait-lightbox-btn member-card-photo-btn"
        data-lightbox="<%= m.portrait_path %>"
        data-lightbox-caption="<%= m.display_name %>"
        aria-label="View full photo of <%= m.display_name %>"
        style="position:absolute;inset:0;width:100%;height:100%;margin:0;padding:0;border:0;background:transparent;cursor:zoom-in;overflow:hidden;display:block;"
      >
        <%/* Empty alt: name is already shown in the card title */%>
        <img
          src="<%= m.portrait_path %>"
          alt=""
          loading="lazy"
          decoding="async"
          data-fallback-initial="<%= (m.display_name || '?').charAt(0) %>"
          style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 18%;display:block;margin:0;padding:0;border:0;border-radius:0;"
          onerror="var w=this.closest('.member-card-photo'); if(w){ w.innerHTML='<div class=\'member-card-placeholder\' aria-hidden=\'true\' style=\'position:absolute;inset:0;display:flex;align-items:center;justify-content:center;\'><span>'+(this.getAttribute('data-fallback-initial')||'?')+'</span></div>'; }"
        />
      </button>
    <% } else { %>
      <div class="member-card-placeholder" aria-hidden="true" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
        <span><%= (m.display_name || "?").charAt(0) %></span>
      </div>
    <% } %>
  </div>
  <div class="member-card-body">
    <h3><%= m.display_name %></h3>
    <% if (m.role_in_family) { %>
      <p class="member-card-role"><%= m.role_in_family %></p>
    <% } %>
    <% if (m.family_branch) { %>
      <p class="member-card-branch"><%= m.family_branch === 'both' ? 'Capoccia · Miotto' : m.family_branch %></p>
    <% } %>
    <a class="btn btn-outline member-card-cta" href="<%= ctaHref %>"><%= ctaLabel %></a>
  </div>
</article>
