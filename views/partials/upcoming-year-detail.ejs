<%
  const u = reunion || {};
  const activities = (u.activities && u.activities.length) ? u.activities : [];
  const pricing = (u.pricing && u.pricing.length) ? u.pricing : [];
  const mapQ = u.map_query || u.full_address || u.address || u.place_name || '';
  const year = u.year || focusYear;
  const title = u.title || focusTitle || (year + ' Capoccia–Miotto Family Reunion');
  const showDetails = typeof hasDetails !== 'undefined' ? hasDetails : false;
%>
<div class="upcoming-hero upcoming-hero--compact<%= isViewingCurrent ? ' upcoming-hero--current' : ' upcoming-hero--archive' %>">
  <div class="upcoming-hero-inner">
    <p class="upcoming-hero-eyebrow">
      <% if (isViewingCurrent) { %>Current reunion<% } else if (year < currentYear) { %>Archived reunion<% } else { %>Planned reunion<% } %>
      · Capoccia · Miotto
    </p>
    <p class="upcoming-hero-year" aria-label="<%= year %>"><%= year %></p>
    <h1 class="upcoming-hero-title">Family Reunion</h1>
    <div class="upcoming-hero-rule" aria-hidden="true"></div>
    <p class="upcoming-hero-sub"><%= title %></p>

    <% if (showDetails) { %>
      <div class="upcoming-hero-facts">
        <% if (u.display_date || u.date_text) { %>
          <div class="upcoming-fact">
            <span class="upcoming-fact-label">Dates</span>
            <span class="upcoming-fact-value"><%= u.display_date || u.date_text %></span>
          </div>
        <% } %>
        <% if (u.place_name || u.location) { %>
          <div class="upcoming-fact">
            <span class="upcoming-fact-label">Place</span>
            <span class="upcoming-fact-value"><%= u.place_name || u.location %></span>
          </div>
        <% } %>
        <% if (u.room_name) { %>
          <div class="upcoming-fact">
            <span class="upcoming-fact-label">Room</span>
            <span class="upcoming-fact-value"><%= u.room_name %></span>
          </div>
        <% } %>
        <% if (u.main_event_when || u.main_event_label) { %>
          <div class="upcoming-fact">
            <span class="upcoming-fact-label"><%= u.main_event_label || 'Main event' %></span>
            <span class="upcoming-fact-value"><%= u.main_event_when || u.event_time || '' %></span>
          </div>
        <% } %>
        <% if (u.full_address || u.address) { %>
          <div class="upcoming-fact upcoming-fact--wide">
            <span class="upcoming-fact-label">Address</span>
            <span class="upcoming-fact-value">
              <% if (mapQ) { %>
                <a
                  class="upcoming-map-link"
                  href="https://www.google.com/maps/search/?api=1&amp;query=<%= encodeURIComponent(mapQ) %>"
                  target="_blank"
                  rel="noopener noreferrer"
                ><%= u.full_address || u.address %></a>
              <% } else { %>
                <%= u.full_address || u.address %>
              <% } %>
            </span>
          </div>
        <% } %>
        <% if (u.host_family) { %>
          <div class="upcoming-fact">
            <span class="upcoming-fact-label">Organizer</span>
            <span class="upcoming-fact-value">
              <%= u.host_family %>
              <% if (u.organizer_email) { %><br /><span class="upcoming-fact-sub"><a class="upcoming-map-link" href="mailto:<%= u.organizer_email %>"><%= u.organizer_email %></a></span><% } %>
              <% if (u.organizer_phone) { %><br /><span class="upcoming-fact-sub"><a class="upcoming-map-link" href="tel:<%= String(u.organizer_phone).replace(/[^\d+]/g,'') %>"><%= u.organizer_phone %></a></span><% } %>
            </span>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <p class="upcoming-hero-status">Details coming soon</p>
      <p class="upcoming-hero-status-lead">
        Official details for <%= year %> will appear here once posted by the family organizer / website administrator.
      </p>
    <% } %>
  </div>
</div>

<% if (showDetails) { %>
  <div class="upcoming-detail-sections">
    <% if (u.summary) { %>
      <section class="upcoming-section">
        <h2 class="upcoming-section-title">Overview</h2>
        <p class="upcoming-section-body"><%= u.summary %></p>
      </section>
    <% } %>

    <% if (u.main_event_label || u.main_event_when || pricing.length) { %>
      <section class="upcoming-section upcoming-section--highlight">
        <h2 class="upcoming-section-title"><%= u.main_event_label || 'Main gathering' %></h2>
        <% if (u.main_event_when) { %>
          <p class="upcoming-highlight-when"><%= u.main_event_when %></p>
        <% } %>
        <% if (u.room_name) { %>
          <p class="upcoming-section-meta">In the <strong><%= u.room_name %></strong><% if (u.place_name) { %> at <%= u.place_name %><% } %></p>
        <% } %>
        <% if (pricing.length) { %>
          <div class="upcoming-price-grid">
            <% pricing.forEach(function(p) { %>
              <div class="upcoming-price-card">
                <div class="upcoming-price-amt"><%= p.price %></div>
                <div class="upcoming-price-label"><%= p.label %></div>
                <% if (p.note) { %><div class="upcoming-price-note"><%= p.note %></div><% } %>
              </div>
            <% }) %>
          </div>
        <% } %>
        <% if (u.payment_info || u.venmo_url) { %>
          <div class="upcoming-payment">
            <% if (u.payment_info) { %><p><%= u.payment_info %></p><% } %>
            <% if (u.venmo_url) { %>
              <p>
                <a class="btn btn-secondary" href="<%= u.venmo_url %>" target="_blank" rel="noopener noreferrer">
                  <%= u.venmo_label || 'Pay with Venmo' %>
                </a>
              </p>
            <% } %>
          </div>
        <% } %>
        <% if (u.rsvp_deadline || u.rsvp_notes) { %>
          <div class="upcoming-rsvp">
            <% if (u.rsvp_deadline) { %>
              <p><strong>RSVP / final count by:</strong>
                <% try {
                  const d = new Date(u.rsvp_deadline + 'T12:00:00');
                  %><%= isNaN(d.getTime()) ? u.rsvp_deadline : d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %><%
                } catch(e) { %><%= u.rsvp_deadline %><% } %>
              </p>
            <% } %>
            <% if (u.rsvp_notes) { %><p><%= u.rsvp_notes %></p><% } %>
            <% if (u.organizer_email) { %>
              <p>Email <a href="mailto:<%= u.organizer_email %>"><%= u.organizer_email %></a><% if (u.host_family) { %> (<%= u.host_family %>)<% } %>.</p>
            <% } %>
            <% if (u.organizer_phone) { %>
              <p>Text or call <a href="tel:<%= String(u.organizer_phone).replace(/[^\d+]/g,'') %>"><%= u.organizer_phone %></a>.</p>
            <% } %>
          </div>
        <% } %>
      </section>
    <% } %>

    <% if (activities.length) { %>
      <section class="upcoming-section">
        <h2 class="upcoming-section-title">Weekend schedule</h2>
        <div class="upcoming-activity-list">
          <% activities.forEach(function(a) { %>
            <article class="upcoming-activity">
              <div class="upcoming-activity-when">
                <% if (a.day_label) { %><span class="upcoming-activity-day"><%= a.day_label %></span><% } %>
                <% if (a.time_text) { %><span class="upcoming-activity-time"><%= a.time_text %></span><% } %>
                <% if (a.activity_date) {
                  try {
                    const ad = new Date(a.activity_date + 'T12:00:00');
                    if (!isNaN(ad.getTime())) { %>
                      <span class="upcoming-activity-date"><%= ad.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
                    <% }
                  } catch (e) {}
                } %>
              </div>
              <div class="upcoming-activity-body">
                <h3 class="upcoming-activity-title"><%= a.title %></h3>
                <% if (a.location) { %><p class="upcoming-activity-loc"><%= a.location %></p><% } %>
                <% if (a.price_info) { %><p class="upcoming-activity-price"><%= a.price_info %></p><% } %>
                <% if (a.notes) { %><p class="upcoming-activity-notes"><%= a.notes %></p><% } %>
                <% if (a.reservation_required) { %><p class="upcoming-activity-rsv">Reservation required — contact the organizer.</p><% } %>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>

    <% if (u.attending_list || u.not_attending_list) { %>
      <section class="upcoming-section">
        <h2 class="upcoming-section-title">Attendance notes</h2>
        <div class="upcoming-lists">
          <% if (u.attending_list) { %>
            <div>
              <h3 class="upcoming-list-heading">Planning to attend</h3>
              <p class="upcoming-list-body"><%= u.attending_list %></p>
            </div>
          <% } %>
          <% if (u.not_attending_list) { %>
            <div>
              <h3 class="upcoming-list-heading">Unable to attend</h3>
              <p class="upcoming-list-body"><%= u.not_attending_list %></p>
            </div>
          <% } %>
        </div>
      </section>
    <% } %>

    <% if (mapQ) { %>
      <section class="upcoming-section upcoming-section--center">
        <h2 class="upcoming-section-title">Find the venue</h2>
        <p class="upcoming-section-body"><%= u.full_address || mapQ %></p>
        <a
          class="btn btn-primary"
          href="https://www.google.com/maps/search/?api=1&amp;query=<%= encodeURIComponent(mapQ) %>"
          target="_blank"
          rel="noopener noreferrer"
        >Open in Google Maps</a>
      </section>
    <% } %>

    <% if (year && year <= currentYear) { %>
      <section class="upcoming-section upcoming-section--center">
        <h2 class="upcoming-section-title">Photos from <%= year %></h2>
        <p class="upcoming-section-body">View the cover photo and year gallery for this reunion.</p>
        <a class="btn btn-outline" href="/reunion/<%= year %>">Open <%= year %> photo page</a>
        <a class="btn btn-outline" href="/photo-archive?year=<%= year %>" style="margin-left:0.5rem">Photo archive</a>
      </section>
    <% } %>
  </div>
<% } %>
