<%- include('partials/header', { pageTitle: 'Photo Archive' }) %>

<% if (!isFiltering) { %>
<section class="section special-memories-section" id="special-memories">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">Treasured moments</p>
      <h2 class="section-title">Special Memories</h2>
      <div class="section-rule"></div>
      <p class="section-lead">
        Favorite photographs from Capoccia–Miotto reunions and family life — the heart of our living archive.
      </p>
    </header>

    <% if (typeof specialMemories !== 'undefined' && specialMemories && specialMemories.length) { %>
      <% const hero = specialMemories[0]; %>
      <% const rest = specialMemories.slice(1); %>
      <% const heroSrc = hero.web_path || hero.original_path || hero.thumb_path; %>
      <% const heroCapParts = [hero.title || "", hero.reunion_year ? String(hero.reunion_year) : "", (hero.description && !/^Portrait of /i.test(String(hero.description))) ? hero.description : ""].filter(Boolean); %>
      <% const heroCap = heroCapParts.join(" — ") || "Special memory"; %>

      <div class="special-memories-showcase">
        <button
          type="button"
          class="special-memory-hero"
          data-lightbox="<%= heroSrc %>"
          data-lightbox-caption="<%= heroCap.replace(/"/g, '&quot;') %>"
          aria-label="View special memory<%= hero.reunion_year ? ' from ' + hero.reunion_year : '' %>"
        >
          <img
            src="<%= hero.web_path || hero.thumb_path || hero.original_path %>"
            alt="<%= hero.title || 'Special memory' %>"
            loading="eager"
          />
          <div class="special-memory-hero-meta">
            <span class="special-memory-badge">Special Memories</span>
            <% if (hero.reunion_year || hero.title) { %>
              <p class="special-memory-hero-cap">
                <% if (hero.title) { %><%= hero.title %><% } %>
                <% if (hero.title && hero.reunion_year) { %> · <% } %>
                <% if (hero.reunion_year) { %><strong><%= hero.reunion_year %></strong><% } %>
              </p>
            <% } %>
            <% if (hero.description && !/^Portrait of /i.test(String(hero.description))) { %>
              <p class="special-memory-hero-desc"><%= hero.description %></p>
            <% } %>
          </div>
        </button>

        <% if (rest.length) { %>
          <div class="special-memories-grid" role="list">
            <% rest.forEach(function(p) { %>
              <% const fullSrc = p.web_path || p.original_path || p.thumb_path; %>
              <% const cap = [p.reunion_year ? String(p.reunion_year) : "", p.title || ""].filter(Boolean).join(" · ") || "Special memory"; %>
              <button
                type="button"
                class="special-memory-tile"
                role="listitem"
                data-lightbox="<%= fullSrc %>"
                data-lightbox-caption="<%= cap %>"
                aria-label="View special memory<%= p.reunion_year ? ' from ' + p.reunion_year : '' %>"
              >
                <img src="<%= p.web_path || p.thumb_path || p.original_path %>" alt="<%= p.title || 'Special memory' %>" loading="lazy" />
                <% if (p.title || p.reunion_year) { %>
                  <div class="special-memory-tile-cap">
                    <% if (p.title) { %><span class="special-memory-title"><%= p.title %></span><% } %>
                    <% if (p.reunion_year) { %><span class="special-memory-year"><%= p.reunion_year %></span><% } %>
                  </div>
                <% } %>
              </button>
            <% }) %>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <div class="empty special-memories-empty">
        <h3>Special memories will appear here</h3>
        <p>Family photographs chosen for this showcase will display as the main gallery on this page.</p>
        <a class="btn btn-primary" href="/contribute">Contribute Family Photos</a>
      </div>
    <% } %>
  </div>
</section>
<% } %>

<section class="section<%= !isFiltering ? ' section-alt' : '' %>" id="full-archive">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">Search the album</p>
      <h2 class="section-title">Photo Archive</h2>
      <div class="section-rule"></div>
      <p class="section-lead">Every family photograph uploaded with the family PIN — including home gallery uploads, member portraits, and board photos — appears here automatically once it is approved (approval is automatic for family PIN logins).</p>
    </header>
    <form class="form-card" method="get" action="/photo-archive" style="margin-bottom:1.5rem">
      <div class="form-row two">
        <div>
          <label for="q">Search</label>
          <input type="text" id="q" name="q" value="<%= q || '' %>" placeholder="Name, place, description…" />
        </div>
        <div>
          <label for="year">Year</label>
          <select id="year" name="year">
            <option value="">All years</option>
            <% years.forEach(function(y) { %><option value="<%= y.year %>" <%= year === y.year ? 'selected' : '' %>><%= y.year %></option><% }) %>
          </select>
        </div>
      </div>
      <div class="form-row two">
        <div>
          <label for="branch">Family branch</label>
          <select id="branch" name="branch">
            <option value="">All</option>
            <option value="Capoccia" <%= branch === 'Capoccia' ? 'selected' : '' %>>Capoccia</option>
            <option value="Miotto" <%= branch === 'Miotto' ? 'selected' : '' %>>Miotto</option>
            <option value="both" <%= branch === 'both' ? 'selected' : '' %>>Both</option>
          </select>
        </div>
        <div>
          <label for="related">Family member</label>
          <select id="related" name="related">
            <option value="">All family members</option>
            <% (familyMembers || []).forEach(function(m) { %>
              <option value="<%= m.id %>" <%= String(related || '') === String(m.id) ? 'selected' : '' %>><%= m.display_name %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <button class="btn btn-primary" type="submit">Search archive</button>
      <% if (isFiltering) { %>
        <a class="btn btn-outline" href="/photo-archive" style="margin-left:0.5rem">Clear filters</a>
      <% } %>
    </form>
    <% if (year) { %>
      <p class="year-gallery-lead" style="text-align:center;margin:-0.5rem 0 1.25rem">
        Showing photographs from <strong><%= year %></strong>.
        <a href="/reunion/<%= year %>">Open <%= year %> reunion page</a>
        (cover photo first, then the year gallery).
      </p>
    <% } %>
    <% if (typeof photoGroups !== 'undefined' && photoGroups && photoGroups.length) { %>
      <% photoGroups.forEach(function(group) { %>
        <section class="archive-family-group" aria-label="<%= group.label %>">
          <header class="archive-family-group-header">
            <h3 class="archive-family-group-title"><%= group.label %></h3>
            <% if (group.relatedMemberId) { %>
              <a class="archive-family-group-link" href="/family-members/<%= group.relatedMemberId %>">View bio</a>
            <% } %>
          </header>
          <div class="photo-grid">
            <% group.photos.forEach(function(p) { %>
              <% const fullSrc = p.web_path || p.original_path || p.thumb_path; %>
              <% const displayName = (p.title || p.person_names || "").trim(); %>
              <% const capParts = []; %>
              <% if (p.reunion_year) capParts.push(String(p.reunion_year)); %>
              <% if (displayName) capParts.push(displayName); %>
              <% const cap = capParts.join(" · ") || "Family photograph"; %>
              <% const hasCap = !!(p.reunion_year || displayName || p.special_memory || p.featured); %>
              <button
                type="button"
                class="photo-tile photo-tile-btn<%= p.featured ? ' photo-tile--cover' : '' %><%= p.special_memory ? ' photo-tile--special' : '' %>"
                data-lightbox="<%= fullSrc %>"
                data-lightbox-caption="<%= cap %>"
                aria-label="View full photo<%= displayName ? ': ' + displayName : (p.reunion_year ? ' from ' + p.reunion_year : '') %>"
              >
                <img src="<%= p.thumb_path || p.web_path %>" alt="<%= displayName || 'Family photograph' %>" loading="lazy" />
                <% if (hasCap) { %>
                  <div class="cap">
                    <% if (p.special_memory) { %><span class="photo-special-tag">Special</span> <% } %>
                    <% if (p.featured) { %><span class="photo-cover-tag">Cover</span> <% } %>
                    <%= capParts.join(" · ") %>
                  </div>
                <% } %>
              </button>
            <% }) %>
          </div>
        </section>
      <% }) %>
    <% } else if (photos.length) { %>
      <div class="photo-grid">
        <% photos.forEach(function(p) { %>
          <% const fullSrc = p.web_path || p.original_path || p.thumb_path; %>
          <% const displayName = (p.title || p.person_names || "").trim(); %>
          <% const capParts = []; %>
          <% if (p.reunion_year) capParts.push(String(p.reunion_year)); %>
          <% if (displayName) capParts.push(displayName); %>
          <% const cap = capParts.join(" · ") || "Family photograph"; %>
          <% const hasCap = !!(p.reunion_year || displayName || p.special_memory || p.featured); %>
          <button
            type="button"
            class="photo-tile photo-tile-btn<%= p.featured ? ' photo-tile--cover' : '' %><%= p.special_memory ? ' photo-tile--special' : '' %>"
            data-lightbox="<%= fullSrc %>"
            data-lightbox-caption="<%= cap %>"
            aria-label="View full photo<%= displayName ? ': ' + displayName : (p.reunion_year ? ' from ' + p.reunion_year : '') %>"
          >
            <img src="<%= p.thumb_path || p.web_path %>" alt="<%= displayName || 'Family photograph' %>" loading="lazy" />
            <% if (hasCap) { %>
              <div class="cap">
                <% if (p.special_memory) { %><span class="photo-special-tag">Special</span> <% } %>
                <% if (p.featured) { %><span class="photo-cover-tag">Cover</span> <% } %>
                <%= capParts.join(" · ") %>
              </div>
            <% } %>
          </button>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty">
        <h3>No photographs yet.</h3>
        <a class="btn btn-primary" href="/contribute">Contribute Family Photos</a>
      </div>
    <% } %>
  </div>
</section>
<%- include('partials/footer') %>
