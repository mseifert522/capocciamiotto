<%- include('partials/header', { pageTitle: reunion.year + ' Reunion' }) %>
<%
  const cover = typeof coverPhoto !== 'undefined' ? coverPhoto : null;
  const gallery = typeof galleryPhotos !== 'undefined' ? galleryPhotos : (photos || []);
  const allPhotos = photos || [];
%>
<section class="section year-section">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">Capoccia–Miotto Family Reunion</p>
      <h2 class="section-title"><%= reunion.year %> Family Reunion</h2>
      <div class="section-rule"></div>
      <p class="section-lead">
        <% if (reunion.no_reunion) { %>
          Family records note that a reunion may not have been held this year. If you know otherwise, please share.
        <% } else { %>
          <% if (reunion.date_text) { %>Date: <%= reunion.date_text %><br /><% } else { %>Date: <em>to be confirmed by family</em><br /><% } %>
          <% if (reunion.location) { %>Location: <%= reunion.location %><br /><% } else { %>Location: <em>to be confirmed by family</em><br /><% } %>
          <% if (reunion.host_family) { %>Host / organizer: <%= reunion.host_family %><% } else { %>Host / organizer: <em>to be confirmed by family</em><% } %>
        <% } %>
      </p>
    </header>

    <% if (cover && (cover.web_path || cover.thumb_path)) { %>
      <figure
        class="year-cover lightbox-zoomable"
        data-lightbox="<%= cover.web_path || cover.original_path || cover.thumb_path %>"
        data-lightbox-caption="<%= cover.title || (reunion.year + ' Capoccia–Miotto Family Reunion') %>"
        role="button"
        tabindex="0"
        aria-label="View full cover photo for <%= reunion.year %>"
      >
        <img
          src="<%= cover.web_path || cover.thumb_path %>"
          alt="<%= cover.title || (reunion.year + ' family reunion cover photograph') %>"
          class="year-cover-img"
          loading="eager"
        />
        <figcaption class="year-cover-cap">
          <span class="year-cover-badge"><%= reunion.year %> cover photo</span>
          <span class="year-cover-title"><%= cover.title || (reunion.year + ' Capoccia–Miotto Family Reunion') %></span>
          <% if (allPhotos.length) { %>
            <span class="year-cover-count"><%= allPhotos.length %> photograph<%= allPhotos.length === 1 ? '' : 's' %> from this year in the archive</span>
          <% } %>
        </figcaption>
      </figure>
    <% } %>

    <div class="btn-row" style="justify-content:center;margin:1.5rem 0 2rem">
      <a class="btn btn-primary" href="/contribute?year=<%= reunion.year %>">Contribute to This Reunion</a>
      <a class="btn btn-secondary" href="/contribute?year=<%= reunion.year %>">Add Photos From This Year</a>
      <a class="btn btn-outline" href="/photo-archive?year=<%= reunion.year %>">View in Photo Archive</a>
      <a class="btn btn-outline" href="/contribute/story">Share a Family Memory</a>
    </div>

    <% if (reunion.summary) { %>
      <div class="narrow" style="margin-bottom:2rem"><p><%= reunion.summary %></p></div>
    <% } %>

    <% if (gallery.length) { %>
      <h3 class="year-gallery-heading">More photographs from <%= reunion.year %></h3>
      <p class="year-gallery-lead">All photos below are also in the <a href="/photo-archive?year=<%= reunion.year %>">Photo Archive</a> for <%= reunion.year %>.</p>
      <div class="photo-grid">
        <% gallery.forEach(function(p) { %>
          <button
            type="button"
            class="photo-tile photo-tile-btn"
            style="margin:0"
            data-lightbox="<%= p.web_path || p.original_path || p.thumb_path %>"
            data-lightbox-caption="<%= p.title || (peopleByPhoto[p.id] && peopleByPhoto[p.id].map(x => x.person_name).join(', ')) || 'Reunion photograph' %>"
            aria-label="View full photo<%= p.title ? ': ' + p.title : '' %>"
          >
            <img src="<%= p.thumb_path || p.web_path %>" alt="<%= p.title || 'Reunion photograph' %>" loading="lazy" />
            <span class="cap"><%= p.title || (peopleByPhoto[p.id] && peopleByPhoto[p.id].map(x => x.person_name).join(', ')) || 'Family photograph' %></span>
          </button>
        <% }) %>
      </div>
    <% } else if (cover) { %>
      <div class="empty" style="margin-top:1rem">
        <h3>This is the cover photo for <%= reunion.year %>.</h3>
        <p>Add more photographs from this reunion to grow the year gallery.</p>
        <a class="btn btn-primary" href="/contribute?year=<%= reunion.year %>">Add Photos From This Year</a>
      </div>
    <% } else { %>
      <div class="empty">
        <h3>No photographs yet from <%= reunion.year %>.</h3>
        <a class="btn btn-primary" href="/contribute?year=<%= reunion.year %>">Add Photos From This Year</a>
      </div>
    <% } %>

    <% if (stories.length) { %>
      <div style="margin-top:2.5rem">
        <h3 class="section-title" style="font-size:1.6rem;text-align:center;margin-bottom:1rem">Family Memories</h3>
        <div class="board-list narrow">
          <% stories.forEach(function(s) { %>
            <article class="board-post">
              <% if (s.title) { %><h3><%= s.title %></h3><% } %>
              <p class="board-meta"><%= s.contributor_name || 'Family member' %></p>
              <p style="white-space:pre-wrap"><%= s.body %></p>
            </article>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>
</section>
<%- include('partials/footer') %>
