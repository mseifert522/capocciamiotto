<%- include('partials/header', { pageTitle: 'Reunion Timeline' }) %>
<%
  // Newest years first (e.g. 2026 at top), then back through history
  const list = (reunions || []).slice().sort(function (a, b) { return b.year - a.year; });
  const withPhotos = list.filter(function (r) { return r.photo_count > 0; }).length;
  const newestYear = list.length ? list[0].year : currentYear;
  const oldestYear = list.length ? list[list.length - 1].year : 1977;
%>
<section class="section tl-section">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">Newest first · then back through history</p>
      <h2 class="section-title">Reunion Timeline</h2>
      <div class="section-rule"></div>
      <p class="section-lead">
        Start with the newest reunions at the top
        (<strong><%= newestYear %></strong>) and scroll back through our history to
        <strong><%= oldestYear %></strong>. Every year is a chapter; open one to view photographs and memories.
      </p>
    </header>

    <div class="invite tl-invite">
      <p><strong>Do you have photographs from any reunion year?</strong> Even one photograph can preserve a moment for future generations.</p>
      <a class="btn btn-primary" href="/contribute">Contribute Family Photos</a>
    </div>

    <div class="tl-stats" aria-label="Timeline summary">
      <div class="tl-stat">
        <span class="tl-stat-n"><%= list.length %></span>
        <span class="tl-stat-l">Years on the timeline</span>
      </div>
      <div class="tl-stat">
        <span class="tl-stat-n"><%= withPhotos %></span>
        <span class="tl-stat-l">Years with photos</span>
      </div>
      <div class="tl-stat">
        <span class="tl-stat-n"><%= oldestYear %>–<%= newestYear %></span>
        <span class="tl-stat-l">Living tradition</span>
      </div>
    </div>

    <div class="tl-rail" role="list">
      <div class="tl-origin" aria-hidden="true">
        <span class="tl-origin-dot"></span>
        <span class="tl-origin-label">Today · newest years first</span>
      </div>

      <% list.forEach(function(r, i) {
        const side = i % 2 === 0 ? "left" : "right";
        const hasPhotos = r.photo_count > 0;
        const state = r.no_reunion ? "none" : (hasPhotos ? "has" : "wait");
        let statusText = "Waiting for photos";
        if (r.no_reunion) statusText = "No reunion noted";
        else if (hasPhotos) statusText = r.photo_count + " photo" + (r.photo_count === 1 ? "" : "s");
        const metaBits = [];
        if (r.location) metaBits.push(r.location);
        if (r.host_family) metaBits.push("Host: " + r.host_family);
        if (r.date_text) metaBits.push(r.date_text);
      %>
        <article class="tl-item tl-item--<%= side %> tl-item--<%= state %>" role="listitem">
          <div class="tl-spine" aria-hidden="true">
            <span class="tl-node"></span>
            <span class="tl-segment"></span>
          </div>
          <div class="tl-card<%= r.cover_photo_path ? ' tl-card--has-cover' : '' %>">
            <div class="tl-card-accent" aria-hidden="true"></div>
            <% if (r.cover_photo_path) { %>
              <a class="tl-card-cover" href="/reunion/<%= r.year %>" aria-label="<%= r.year %> reunion cover photo">
                <img
                  src="<%= r.cover_thumb_path || r.cover_photo_path %>"
                  alt="<%= r.year %> Capoccia–Miotto Family Reunion group photo"
                  loading="lazy"
                  width="760"
                  height="380"
                />
                <span class="tl-card-cover-label"><%= r.year %> cover</span>
              </a>
            <% } %>
            <div class="tl-card-body">
              <a class="tl-card-main" href="/reunion/<%= r.year %>">
                <div class="tl-card-top">
                  <span class="tl-year"><%= r.year %></span>
                  <span class="tl-badge tl-badge--<%= state %>">
                    <% if (state === "has") { %>In the archive
                    <% } else if (state === "none") { %>No reunion
                    <% } else { %>Open chapter
                    <% } %>
                  </span>
                </div>
                <h3 class="tl-card-title"><%= r.title || (r.year + " Family Reunion") %></h3>
                <% if (metaBits.length) { %>
                  <p class="tl-card-meta"><%= metaBits.join(" · ") %></p>
                <% } %>
                <p class="tl-card-status"><%= statusText %></p>
              </a>
              <div class="tl-card-actions">
                <a class="tl-card-cta" href="/reunion/<%= r.year %>">View <%= r.year %> <span aria-hidden="true">→</span></a>
                <a class="tl-card-add" href="/contribute?year=<%= r.year %>">Add photos</a>
              </div>
            </div>
          </div>
        </article>
      <% }) %>

      <div class="tl-today" aria-hidden="true">
        <span class="tl-today-dot"></span>
        <span class="tl-today-label">1977 · where our reunion tradition began</span>
      </div>
    </div>

    <div class="empty tl-footer-cta" style="margin-top:2.5rem">
      <h3>Help complete a reunion year</h3>
      <p>If a year is waiting for photographs, your album may hold the missing piece.</p>
      <a class="btn btn-secondary" href="/contribute">Share family photos</a>
      <a class="btn btn-outline" href="/photo-archive" style="margin-left:0.5rem">Browse photo archive</a>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
