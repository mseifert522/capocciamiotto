<%- include('partials/header', { pageTitle: 'Upcoming Reunion' }) %>
<%
  const u = upcoming || {};
  const tabs = yearTabs || [];
  const emailQs = showAdminForm ? '&email=1' : '';
%>
<section class="upcoming-page">
  <div class="container upcoming-shell">
    <aside class="upcoming-year-nav" aria-label="Reunion years">
      <div class="upcoming-year-nav-head">
        <h2 class="upcoming-year-nav-title">Reunion years</h2>
        <p class="upcoming-year-nav-lead">Current year first. Browse the archive for past details.</p>
      </div>
      <nav class="upcoming-year-tabs" role="tablist">
        <% tabs.forEach(function(t) {
          const active = t.year === focusYear;
          let badge = '';
          if (t.isCurrent || t.year === primaryYear) badge = 'Current';
          else if (t.isPast) badge = 'Archive';
          else if (t.isFuture) badge = 'Planned';
        %>
          <a
            class="upcoming-year-tab<%= active ? ' is-active' : '' %><%= (t.isCurrent || t.year === primaryYear) ? ' is-current' : '' %><%= t.isPast ? ' is-past' : '' %>"
            href="/upcoming-reunion?year=<%= t.year %><%= showAdminForm ? '&email=1' : '' %>"
            role="tab"
            aria-selected="<%= active ? 'true' : 'false' %>"
          >
            <span class="upcoming-year-tab-year"><%= t.year %></span>
            <% if (badge) { %><span class="upcoming-year-tab-badge"><%= badge %></span><% } %>
            <span class="upcoming-year-tab-meta">
              <% if (t.date_text) { %><%= t.date_text %><% } else if (t.place) { %><%= t.place %><% } else if (t.hasDetails) { %>Details on file<% } else { %>Details pending<% } %>
            </span>
          </a>
        <% }) %>
      </nav>
      <p class="upcoming-year-nav-foot">
        Photos by year live on the
        <a href="/reunion-timeline">Reunion Timeline</a>.
      </p>
    </aside>

    <div class="upcoming-main" role="tabpanel">
      <%- include('partials/upcoming-year-detail', {
        reunion: u,
        hasDetails: hasDetails,
        focusYear: focusYear,
        focusTitle: focusTitle,
        isViewingCurrent: isViewingCurrent,
        currentYear: currentYear
      }) %>

      <div class="upcoming-page-body">
        <% if (isViewingCurrent) { %>
          <div class="upcoming-admin-cta card">
            <div class="card-body" style="text-align:center">
              <h2 class="upcoming-admin-cta-title">Updates or corrections for <%= focusYear %>?</h2>
              <p class="upcoming-admin-cta-text">
                Organizers can email changes (date, room, pricing, RSVP list, or activities) to the website administrator.
                Official details are archived by year so the family can always look back.
              </p>
              <a class="btn btn-primary btn-lg upcoming-email-admin-btn" href="/upcoming-reunion?year=<%= focusYear %>&amp;email=1#email-admin">
                Email admin of the website
              </a>
            </div>
          </div>
        <% } else { %>
          <div class="upcoming-admin-cta card upcoming-admin-cta--muted">
            <div class="card-body" style="text-align:center">
              <h2 class="upcoming-admin-cta-title"><%= focusYear %> archive</h2>
              <p class="upcoming-admin-cta-text">
                You are viewing archived reunion information.
                <a href="/upcoming-reunion?year=<%= primaryYear %>">Return to <%= primaryYear %> (current)</a>
              </p>
            </div>
          </div>
        <% } %>

        <% if (showAdminForm) { %>
          <div class="upcoming-email-panel" id="email-admin">
            <h3 class="upcoming-email-panel-title">Email admin of the website</h3>
            <p class="upcoming-email-panel-lead">
              Send <%= focusYear %> reunion details or corrections. Your message is emailed for review and kept with that year’s archive when posted.
            </p>
            <form class="form-card" method="post" action="/upcoming-reunion/email-admin" style="max-width:540px;margin:0 auto">
              <input type="hidden" name="year" value="<%= focusYear %>" />
              <div class="form-row two">
                <div>
                  <label for="organizer_name">Your name *</label>
                  <input id="organizer_name" name="organizer_name" type="text" required maxlength="120" autocomplete="name" />
                </div>
                <div>
                  <label for="organizer_email">Your email *</label>
                  <input id="organizer_email" name="organizer_email" type="email" required maxlength="160" autocomplete="email" />
                </div>
              </div>
              <div class="form-row">
                <label for="phone">Phone (optional)</label>
                <input id="phone" name="phone" type="tel" maxlength="40" autocomplete="tel" />
              </div>
              <div class="form-row two">
                <div>
                  <label for="event_date">Reunion start date</label>
                  <input id="event_date" name="event_date" type="date" value="<%= u.event_date || '' %>" />
                </div>
                <div>
                  <label for="event_time">Key time</label>
                  <input id="event_time" name="event_time" type="text" maxlength="80" placeholder="e.g. Sunday lunch at noon" value="<%= u.main_event_when || u.event_time || '' %>" />
                </div>
              </div>
              <div class="form-row">
                <label for="place_name">Name of place</label>
                <input id="place_name" name="place_name" type="text" maxlength="200" value="<%= u.place_name || '' %>" />
              </div>
              <div class="form-row">
                <label for="address">Address</label>
                <input id="address" name="address" type="text" maxlength="300" value="<%= u.full_address || u.address || '' %>" />
              </div>
              <div class="form-row">
                <label for="notes">Details / corrections for the administrator</label>
                <textarea id="notes" name="notes" rows="4" maxlength="4000" placeholder="Room name, pricing, activities, RSVP list changes, etc."></textarea>
              </div>
              <button class="btn btn-primary btn-block" type="submit">Send details to website admin</button>
              <p style="text-align:center;margin-top:0.85rem">
                <a href="/upcoming-reunion?year=<%= focusYear %>" style="font-family:var(--font-ui);font-size:0.9rem">Cancel</a>
              </p>
            </form>
          </div>
        <% } %>

        <div class="btn-row" style="margin-top:2rem;justify-content:center">
          <a class="btn btn-outline" href="/community-board">Community Board</a>
          <a class="btn btn-outline" href="/reunion-timeline">Reunion Timeline &amp; photos</a>
        </div>
      </div>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
