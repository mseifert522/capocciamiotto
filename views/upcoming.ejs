<%- include('partials/header', { pageTitle: 'Upcoming Reunion' }) %>
<section class="upcoming-page">
  <div class="upcoming-hero">
    <div class="upcoming-hero-inner container">
      <p class="upcoming-hero-eyebrow">Capoccia · Miotto</p>
      <p class="upcoming-hero-year" aria-label="<%= focusYear %>"><%= focusYear %></p>
      <h1 class="upcoming-hero-title">Family Reunion</h1>
      <div class="upcoming-hero-rule" aria-hidden="true"></div>
      <p class="upcoming-hero-sub"><%= focusTitle || (focusYear + ' Capoccia–Miotto Family Reunion') %></p>

      <% if (hasDetails && upcoming) { %>
        <div class="upcoming-hero-facts">
          <% if (upcoming.display_date || upcoming.event_date || upcoming.date_text) { %>
            <div class="upcoming-fact">
              <span class="upcoming-fact-label">Date</span>
              <span class="upcoming-fact-value"><%= upcoming.display_date || upcoming.date_text || upcoming.event_date %></span>
            </div>
          <% } %>
          <% if (upcoming.event_time) { %>
            <div class="upcoming-fact">
              <span class="upcoming-fact-label">Time</span>
              <span class="upcoming-fact-value"><%= upcoming.event_time %></span>
            </div>
          <% } %>
          <% if (upcoming.place_name) { %>
            <div class="upcoming-fact">
              <span class="upcoming-fact-label">Place</span>
              <span class="upcoming-fact-value"><%= upcoming.place_name %></span>
            </div>
          <% } %>
          <% if (upcoming.address) { %>
            <div class="upcoming-fact upcoming-fact--wide">
              <span class="upcoming-fact-label">Address</span>
              <span class="upcoming-fact-value">
                <a
                  class="upcoming-map-link"
                  href="https://www.google.com/maps/search/?api=1&amp;query=<%= encodeURIComponent(upcoming.address) %>"
                  target="_blank"
                  rel="noopener noreferrer"
                ><%= upcoming.address %></a>
              </span>
            </div>
          <% } %>
          <% if (upcoming.host_family) { %>
            <div class="upcoming-fact">
              <span class="upcoming-fact-label">Organizer</span>
              <span class="upcoming-fact-value"><%= upcoming.host_family %></span>
            </div>
          <% } %>
        </div>
        <% if (upcoming.summary) { %>
          <p class="upcoming-hero-notes"><%= upcoming.summary %></p>
        <% } %>
      <% } else { %>
        <p class="upcoming-hero-status">Details coming soon</p>
        <p class="upcoming-hero-status-lead">
          Official date, time, place, and address for the <%= focusYear %> reunion will appear here once the website administrator posts them.
        </p>
      <% } %>
    </div>
  </div>

  <div class="container narrow upcoming-page-body">
    <div class="upcoming-admin-cta card">
      <div class="card-body" style="text-align:center">
        <h2 class="upcoming-admin-cta-title">Organizing the <%= focusYear %> reunion?</h2>
        <p class="upcoming-admin-cta-text">
          If you are in charge this year, send the date, time, name of place, and address to the website administrator.
          Details are not entered on this page — they are emailed for review and then posted for the family.
        </p>
        <a class="btn btn-primary btn-lg upcoming-email-admin-btn" href="/upcoming-reunion?email=1#email-admin">
          Email admin of the website
        </a>
      </div>
    </div>

    <% if (showAdminForm) { %>
      <div class="upcoming-email-panel" id="email-admin">
        <h3 class="upcoming-email-panel-title">Email admin of the website</h3>
        <p class="upcoming-email-panel-lead">
          Complete the fields below. Your message will be emailed to the website administrator
          (not published on this page until they post it).
        </p>
        <form class="form-card" method="post" action="/upcoming-reunion/email-admin" style="max-width:540px;margin:0 auto">
          <input type="hidden" name="year" value="<%= focusYear %>" />
          <div class="form-row two">
            <div>
              <label for="organizer_name">Your name *</label>
              <input id="organizer_name" name="organizer_name" type="text" required maxlength="120" autocomplete="name" />
            </div>
            <div>
              <label for="organizer_email">Your email *</label>
              <input id="organizer_email" name="organizer_email" type="email" required maxlength="160" autocomplete="email" />
            </div>
          </div>
          <div class="form-row">
            <label for="phone">Phone (optional)</label>
            <input id="phone" name="phone" type="tel" maxlength="40" autocomplete="tel" />
          </div>
          <div class="form-row two">
            <div>
              <label for="event_date">Reunion date</label>
              <input id="event_date" name="event_date" type="date" />
            </div>
            <div>
              <label for="event_time">Time</label>
              <input id="event_time" name="event_time" type="text" maxlength="80" placeholder="e.g. 1:00 PM – 6:00 PM" />
            </div>
          </div>
          <div class="form-row">
            <label for="place_name">Name of place</label>
            <input id="place_name" name="place_name" type="text" maxlength="200" placeholder="Park, hall, pavilion, or home" />
          </div>
          <div class="form-row">
            <label for="address">Address</label>
            <input id="address" name="address" type="text" maxlength="300" placeholder="Street, city, state, ZIP" />
          </div>
          <div class="form-row">
            <label for="notes">Notes for the administrator (optional)</label>
            <textarea id="notes" name="notes" rows="3" maxlength="2000" placeholder="Parking, rain plan, dish to pass, etc."></textarea>
          </div>
          <p class="hint" style="margin-bottom:1rem">
            Please include at least one of: date, time, place name, or address.
          </p>
          <button class="btn btn-primary btn-block" type="submit">Send details to website admin</button>
          <p style="text-align:center;margin-top:0.85rem">
            <a href="/upcoming-reunion" style="font-family:var(--font-ui);font-size:0.9rem">Cancel</a>
          </p>
        </form>
      </div>
    <% } %>

    <div class="btn-row" style="margin-top:2rem;justify-content:center">
      <a class="btn btn-outline" href="/community-board">Community Board</a>
      <a class="btn btn-outline" href="/reunion-timeline">Reunion Timeline</a>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
